			if _G.NoclipEnabled then
				for _, child in ipairs(myChar:GetChildren()) do
					if child:IsA("BasePart") then child.CanCollide = false end
				end
			end

			-- Custom Angular Spin Engine
			if _G.SpinEnabled then
				local clampedSpin = math.clamp(_G.SpinSpeed, 0, 500)
				myRoot.RotVelocity = Vector3.new(0, clampedSpin, 0)
			end
		end
	end
end)

