local function updateStatusLabel()
    local tpart = tostring(_G.TargetPart or "HumanoidRootPart")
    local size = tostring(_G.HeadSize or 0)
    local teamText = _G.TeamCheck and "(ON)" or "(OFF)"
    statusLabel.Text = ("Target: %s    Size: %s    TeamCheck: %s"):format(tpart, size, teamText)
end

btnToggle.MouseButton1Click:Connect(function()
    _G.Disabled = not _G.Disabled
    if not _G.Disabled then
        restoreAll()
    else
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                applyToPlayer(p)
            end
        end
    end
    updateStatusLabel()
end)

btnChange.MouseButton1Click:Connect(function()
    restoreAll()
    if _G.TargetPart == "HumanoidRootPart" then
        _G.TargetPart = "Head"
    else
        _G.TargetPart = "HumanoidRootPart"
    end
    if _G.Disabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                applyToPlayer(p)
            end
        end
    end
    updateStatusLabel()
end)

btnDecrease.MouseButton1Click:Connect(function()
    _G.HeadSize = math.max(1, (_G.HeadSize or 5) - SIZE_STEP)
    if _G.Disabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                applyToPlayer(p)
            end
        end
    end
    updateStatusLabel()
end)

btnIncrease.MouseButton1Click:Connect(function()
    _G.HeadSize = (_G.HeadSize or 5) + SIZE_STEP
    if _G.Disabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                applyToPlayer(p)
            end
        end
    end
    updateStatusLabel()
end)

btnTeamCheck.MouseButton1Click:Connect(function()
    _G.TeamCheck = not _G.TeamCheck
    -- when toggling team check we should reapply/restore appropriately
    restoreAll()
    if _G.Disabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                applyToPlayer(p)
            end
        end
    end
    updateStatusLabel()
end)

-- initial status
updateStatusLabel()
