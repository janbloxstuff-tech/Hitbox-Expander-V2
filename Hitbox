local function globalESPUpdate()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if _G.ESPEnabled and (not _G.TeamCheck or p.Team ~= LocalPlayer.Team) then
                if not playerLabels[p] then graphics.createESPLabel(p) end
                if not _G.EspHighlights[p] then graphics.createESPHighlight(p) end
            else
                graphics.removeESPHighlight(p)
                graphics.removeESPLabel(p)
                if p.Character then
                    local hum = p.Character:FindFirstChildOfClass("Humanoid")
                    if hum then utils.safeSetProperty(hum, "DisplayDistanceType", Enum.HumanoidDisplayDistanceType.Viewer) end
                end
            end
        end
    end
    
    for npc, _ in pairs(trackedNPCs) do
        if npc and npc.Parent then
            if _G.NPCESPEnabled then
                if not npcLabels[npc] then graphics.createNPCLabel(npc) end
            else
                graphics.removeNPCLabel(npc)
                local hum = npc:FindFirstChildOfClass("Humanoid")
                if hum then utils.safeSetProperty(hum, "DisplayDistanceType", Enum.HumanoidDisplayDistanceType.Viewer) end
            end
        end
    end
end

