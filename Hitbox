-- JanBlox Gui Pro Version (LocalScript)
-- Place this script in StarterPlayerScripts (NOT StarterGui). It will create the ScreenGui under PlayerGui at runtime.

-- Defaults & globals
_G.HeadSize = 5                -- default size
_G.Disabled = true             -- when true, hitboxes are active (keeps original behavior)
_G.TargetPart = "HumanoidRootPart" -- "HumanoidRootPart" or "Head"
_G.TeamCheck = false           -- when true, hide hitboxes on your team (if teams exist)
local SIZE_STEP = 5            -- step for increase/decrease

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TeamsService = game:GetService("Teams")
local LocalPlayer = Players.LocalPlayer

-- Store original properties per player by userId
-- originalProps[userId] = { [partName] = { Size, Transparency, BrickColor, Material, CanCollide, CanQuery, mesh = {className, props} } }
local originalProps = {}

local function userKey(player)
    return tostring(player.UserId or player.Name)
end

local function hasTeams()
    local teams = TeamsService:GetTeams()
    return #teams >= 2
end

-- Record mesh info and then remove it from part
local function captureAndRemoveMesh(part, storeTable)
    for _, child in ipairs(part:GetChildren()) do
        if child:IsA("SpecialMesh") or child:IsA("BlockMesh") or child:IsA("CylinderMesh") or child:IsA("FileMesh") then
            local meshInfo = { className = child.ClassName, properties = {} }
            pcall(function()
                if child:IsA("SpecialMesh") then
                    meshInfo.properties.MeshId = child.MeshId
                    meshInfo.properties.TextureId = child.TextureId
                    meshInfo.properties.Offset = child.Offset
                    meshInfo.properties.Scale = child.Scale
                    meshInfo.properties.MeshType = child.MeshType
                else
                    meshInfo.properties.Scale = child.Scale
                    meshInfo.properties.Offset = child.Offset
                    meshInfo.properties.MeshId = child.MeshId
                    meshInfo.properties.TextureId = child.TextureId
                end
            end)
            storeTable.mesh = meshInfo
            pcall(function() child:Destroy() end)
            break
        end
    end
end

local function recreateMesh(part, meshInfo)
    if not meshInfo or not meshInfo.className then return end
    pcall(function()
        local newMesh = Instance.new(meshInfo.className)
        newMesh.Name = meshInfo.className
        local props = meshInfo.properties or {}
        if newMesh:IsA("SpecialMesh") then
            if props.MeshId then newMesh.MeshId = props.MeshId end
            if props.TextureId then newMesh.TextureId = props.TextureId end
            if props.Offset then newMesh.Offset = props.Offset end
            if props.Scale then newMesh.Scale = props.Scale end
            if props.MeshType then newMesh.MeshType = props.MeshType end
        else
            if props.Scale then newMesh.Scale = props.Scale end
            if props.Offset then newMesh.Offset = props.Offset end
            if props.MeshId then newMesh.MeshId = props.MeshId end
            if props.TextureId then newMesh.TextureId = props.TextureId end
        end
        newMesh.Parent = part
    end)
end

local function storeOriginal(player, partName)
    if not player or not player.Character then return end
    local key = userKey(player)
    originalProps[key] = originalProps[key] or {}
    if originalProps[key][partName] then return end -- already saved

    local part = player.Character:FindFirstChild(partName)
    if part and part:IsA("BasePart") then
        local data = {}
        data.Size = part.Size
        data.Transparency = part.Transparency
        data.BrickColor = part.BrickColor
        data.Material = part.Material
        data.CanCollide = part.CanCollide
        pcall(function() data.CanQuery = part.CanQuery end)
        captureAndRemoveMesh(part, data)
        originalProps[key][partName] = data
    end
end

local function applyToPlayer(player)
    if not player or not player.Character then return end
    if player == LocalPlayer then return end

    if _G.TeamCheck and hasTeams() then
        if player.Team == LocalPlayer.Team then
            return
        end
    end

    pcall(function()
        local targetPart = player.Character:FindFirstChild(_G.TargetPart)
        if not targetPart or not targetPart:IsA("BasePart") then
            targetPart = player.Character:FindFirstChild("HumanoidRootPart")
            if not targetPart then return end
        end

        storeOriginal(player, targetPart.Name)

        targetPart.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize)
        targetPart.Transparency = 0.7
        targetPart.BrickColor = BrickColor.new("Really blue")
        targetPart.Material = Enum.Material.Neon
        targetPart.CanCollide = false
        pcall(function() targetPart.CanQuery = false end)
        -- mesh removal for Head handled in storeOriginal
    end)
end

local function restorePlayer(player)
    if not player then return end
    local key = userKey(player)
    local data = originalProps[key]
    if not data or not player.Character then
        originalProps[key] = nil
        return
    end

    for partName, props in pairs(data) do
        local part = player.Character:FindFirstChild(partName)
        if part and part:IsA("BasePart") and props then
            pcall(function()
                if props.Size then part.Size = props.Size end
                if props.Transparency then part.Transparency = props.Transparency end
                if props.BrickColor then part.BrickColor = props.BrickColor end
                if props.Material then part.Material = props.Material end
                if props.CanCollide ~= nil then part.CanCollide = props.CanCollide end
                if props.CanQuery ~= nil then pcall(function() part.CanQuery = props.CanQuery end) end
                if props.mesh then recreateMesh(part, props.mesh) end
            end)
        end
    end

    originalProps[key] = nil
end

local function restoreAll()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            restorePlayer(player)
        end
    end
end

-- Ensure we clean up & restore when character is removed or player dies
local function onCharacterAdded(player, character)
    if player == LocalPlayer then return end

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.Died:Connect(function()
            restorePlayer(player)
        end)
    end

    character.AncestryChanged:Connect(function(_, parent)
        if not parent then
            restorePlayer(player)
        end
    end)

    if _G.Disabled then
        wait(0.1)
        applyToPlayer(player)
    end
end

Players.PlayerAdded:Connect(function(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function(char) onCharacterAdded(player, char) end)
    player.CharacterRemoving:Connect(function() restorePlayer(player) end)
end)

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        if player.Character then
            onCharacterAdded(player, player.Character)
        end
        player.CharacterAdded:Connect(function(char) onCharacterAdded(player, char) end)
        player.CharacterRemoving:Connect(function() restorePlayer(player) end)
    end
end

RunService.RenderStepped:Connect(function()
    if _G.Disabled then
        for _, v in next, Players:GetPlayers() do
            if v ~= LocalPlayer then
                if v.Character then
                    applyToPlayer(v)
                end
            end
        end
    end
end)

Players.PlayerRemoving:Connect(function(player)
    restorePlayer(player)
    originalProps[userKey(player)] = nil
end)

