-- PART 2: Memory Registration Framework & Object Recovery
local utils = _G.CoreUtils
local Players, LocalPlayer = utils.Players, utils.LocalPlayer
local originalProps, npcHitboxes, hiddenGuis = _G.OriginalProps, _G.NpcHitboxes, _G.HiddenGuis

local function storeOriginal(player, partName)
    if not player or not player.Character then return end
    if not originalProps[player] then originalProps[player] = {} end
    if originalProps[player][partName] then return end
    local part = player.Character:FindFirstChild(partName)
    if part and part:IsA("BasePart") then
        originalProps[player][partName] = {
            Size = part.Size, Transparency = part.Transparency,
            BrickColor = part.BrickColor, Material = part.Material,
            CanCollide = part.CanCollide, Massless = part.Massless 
        }
    end
end

local function storeNPCOriginal(npc, partName)
    if not npc then return end
    if not npcHitboxes[npc] then npcHitboxes[npc] = {} end
    if npcHitboxes[npc][partName] then return end
    local part = npc:FindFirstChild(partName)
    if part and part:IsA("BasePart") then
        npcHitboxes[npc][partName] = {
            Size = part.Size, Transparency = part.Transparency,
            BrickColor = part.BrickColor, Material = part.Material,
            CanCollide = part.CanCollide, Massless = part.Massless 
        }
    end
end

local function restorePlayer(player)
    if not player then return end
    local data = originalProps[player]
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then utils.safeSetProperty(hum, "DisplayDistanceType", Enum.HumanoidDisplayDistanceType.Viewer) end
        if hiddenGuis[player] then
            for _, gui in ipairs(hiddenGuis[player]) do if gui and gui.Parent then utils.safeSetProperty(gui, "Enabled", true) end end
            hiddenGuis[player] = nil
        end
    end
    if not data then originalProps[player] = nil; return end
    if player.Character then
        for partName, props in pairs(data) do
            local part = player.Character:FindFirstChild(partName)
            if part and part:IsA("BasePart") and props then
                utils.safeSetProperty(part, "Size", props.Size)
                utils.safeSetProperty(part, "Transparency", props.Transparency)
                utils.safeSetProperty(part, "BrickColor", props.BrickColor)
                utils.safeSetProperty(part, "Material", props.Material)
                utils.safeSetProperty(part, "CanCollide", props.CanCollide)
                utils.safeSetProperty(part, "Massless", props.Massless)
            end
        end
    end
    originalProps[player] = nil
end

local function restoreNPC(npc)
    if not npc then return end
    local data = npcHitboxes[npc]
    if hiddenGuis[npc] then
        for _, gui in ipairs(hiddenGuis[npc]) do if gui and gui.Parent then utils.safeSetProperty(gui, "Enabled", true) end end
        hiddenGuis[npc] = nil
    end
    local hum = npc:FindFirstChildOfClass("Humanoid")
    if hum then utils.safeSetProperty(hum, "DisplayDistanceType", Enum.HumanoidDisplayDistanceType.Viewer) end
    if not data then return end
    for partName, props in pairs(data) do
        local part = npc:FindFirstChild(partName)
        if part and part:IsA("BasePart") and props then
            utils.safeSetProperty(part, "Size", props.Size)
            utils.safeSetProperty(part, "Transparency", props.Transparency)
            utils.safeSetProperty(part, "BrickColor", props.BrickColor)
            utils.safeSetProperty(part, "Material", props.Material)
            utils.safeSetProperty(part, "CanCollide", props.CanCollide)
            utils.safeSetProperty(part, "Massless", props.Massless)
        end
    end
    npcHitboxes[npc] = nil
end

_G.Mechanics = {
    shouldApplyHitbox = function(player)
        if _G.CheckForcefield and player.Character and utils.hasForceField(player.Character) then return false end
        if player.Team and _G.DisabledTeams[player.Team.Name] then return false end
        if not _G.TeamCheck then return true end
        return player.Team ~= LocalPlayer.Team
    end,
    restorePlayer = restorePlayer,
    restoreNPC = restoreNPC,
    restoreAll = function()
        for _, player in ipairs(Players:GetPlayers()) do if player ~= LocalPlayer then restorePlayer(player) end end
    end,
    restoreAllNPCs = function()
        for npc, _ in pairs(npcHitboxes) do restoreNPC(npc) end
        _G.TrackedNPCs = {}
    end,
    storeOriginal = storeOriginal,
    storeNPCOriginal = storeNPCOriginal
}

-- PART 3: Graphics Modification Engine, ESP, and Teleport Pipeline
local utils = _G.CoreUtils
local espHighlights, playerLabels, npcLabels = _G.EspHighlights, _G.PlayerLabels, _G.NpcLabels

_G.GraphicsEngine = {
    removeESPHighlight = function(player)
        if espHighlights[player] then pcall(function() espHighlights[player]:Destroy() end) espHighlights[player] = nil end
    end,
    removeESPLabel = function(player)
        if playerLabels[player] then pcall(function() playerLabels[player].gui:Destroy() end) playerLabels[player] = nil end
    end,
    removeNPCLabel = function(npc)
        if npcLabels[npc] then pcall(function() npcLabels[npc].gui:Destroy() end) npcLabels[npc] = nil end
    end,
    createESPHighlight = function(player)
        if not player.Character then return end
        for _, c in ipairs(player.Character:GetChildren()) do if c:IsA("Highlight") then pcall(function() c:Destroy() end) end end
        pcall(function()
            local hl = Instance.new("Highlight")
            hl.Adornee = player.Character
            hl.FillColor = utils.getTeamColor(player)
            hl.OutlineColor = utils.getTeamColor(player)
            hl.Parent = player.Character
            espHighlights[player] = hl
        end)
    end,
    createESPLabel = function(player)
        -- Clean up any existing label first
        if playerLabels[player] then 
            pcall(function() playerLabels[player].gui:Destroy() end) 
            playerLabels[player] = nil 
        end
        
        local char = player.Character or player.CharacterAdded:Wait()
        local root = char:WaitForChild("Head", 5) or char:WaitForChild("HumanoidRootPart", 5)
        if not root then return end
        
        pcall(function()
            local bGui = Instance.new("BillboardGui")
            bGui.Size = UDim2.new(5, 0, 2, 0)
            bGui.AlwaysOnTop = true
            bGui.MaxDistance = math.huge
            bGui.ExtentsOffset = Vector3.new(0, 2, 0)
            bGui.Name = "ESPLabel_" .. player.Name
            bGui.Parent = root
            
            local lbl = Instance.new("TextLabel")
            lbl.BackgroundTransparency = 1
            lbl.Size = UDim2.new(1, 0, 1, 0)
            lbl.Font = Enum.Font.GothamBold
            lbl.TextSize = 12
            lbl.TextColor3 = utils.getTeamColor(player)
            lbl.TextStrokeTransparency = 0
            lbl.TextStrokeColor3 = Color3.fromRGB(0,0,0)
            lbl.Parent = bGui
            
            playerLabels[player] = {gui = bGui, label = lbl}
            
            -- Dynamic text updating loop
            task.spawn(function()
                while bGui and bGui.Parent and player.Character == char do
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    local nameStr = _G.ShowName and player.DisplayName or ""
                    local healthStr = ""
                    if hum and _G.ShowHealth then
                        healthStr = " [" .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth) .. "]"
                    end
                    lbl.Text = nameStr .. healthStr
                    task.wait(0.2)
                end
            end)
        end)
    end,
    createNPCLabel = function(npc)
        if npcLabels[npc] then pcall(function() npcLabels[npc].gui:Destroy() end) npcLabels[npc] = nil end
        local root = npc:FindFirstChild("Head") or npc:FindFirstChild("HumanoidRootPart")
        if not root then return end
        pcall(function()
            local bGui = Instance.new("BillboardGui")
            bGui.Size = UDim2.new(4, 0, 1.5, 0); bGui.AlwaysOnTop = true; bGui.MaxDistance = math.huge
            bGui.Name = "NPCESP_" .. npc.Name; bGui.Parent = root
            local lbl = Instance.new("TextLabel")
            lbl.BackgroundTransparency = 1; lbl.Size = UDim2.new(1,0,1,0); lbl.Font = Enum.Font.GothamBold
            lbl.TextSize = 13; lbl.TextColor3 = Color3.fromRGB(255, 255, 100); lbl.TextStrokeTransparency = 0
            lbl.TextStrokeColor3 = Color3.fromRGB(0,0,0); lbl.Parent = bGui
            npcLabels[npc] = {gui = bGui, label = lbl}
        end)
    end
}

_G.FlingEngine = {
    fling = function(targetName)
        if targetName == "" then return end
        local targetPlayer = nil
        for _, p in ipairs(utils.Players:GetPlayers()) do
            if string.lower(p.Name) == string.lower(targetName) or string.lower(p.DisplayName) == string.lower(targetName) then
                targetPlayer = p; break
            end
        end
        if not targetPlayer or targetPlayer == utils.LocalPlayer or not targetPlayer.Character then return end
        local tRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local myChar = utils.LocalPlayer.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")
        if not tRoot or not myRoot or not myHum or myHum.SeatPart then return end
        local oldV = myRoot.AssemblyLinearVelocity
        local oldC = myRoot.CFrame
        local bV = Instance.new("BodyVelocity")
        bV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bV.Velocity = Vector3.new(99999, 99999, 99999)
        bV.Parent = myRoot
        local start = os.clock()
        while os.clock() - start < 0.4 do
            utils.RunService.Heartbeat:Wait()
            if tRoot and myRoot and not myHum.SeatPart then
                myRoot.CFrame = tRoot.CFrame + Vector3.new(math.random(-1,1), 0, math.random(-1,1))
            else break end
        end
        bV:Destroy()
        myRoot.AssemblyLinearVelocity = oldV
        myRoot.CFrame = oldC
    end
}

-- Efficient NPC tracking to avoid scanning the whole workspace every frame
local function isNPCModel(model)
    if not model or not model:IsA("Model") then return false end
    local hum = model:FindFirstChildOfClass("Humanoid")
    return hum ~= nil and not Players:GetPlayerFromCharacter(model)
end

local function trackNPC(model)
    if not isNPCModel(model) then return end
    trackedNPCs[model] = true
end

local function untrackNPC(model)
    if not model then return end
    if trackedNPCs[model] then
        mech.restoreNPC(model)
        graphics.removeNPCLabel(model)
        trackedNPCs[model] = nil
    end
end

for _, desc in ipairs(Workspace:GetDescendants()) do
    if desc:IsA("Humanoid") and desc.Parent and isNPCModel(desc.Parent) then
        trackNPC(desc.Parent)
    end
end

Workspace.DescendantAdded:Connect(function(desc)
    if desc:IsA("Humanoid") and desc.Parent and isNPCModel(desc.Parent) then
        trackNPC(desc.Parent)
    end
end)

Workspace.DescendantRemoving:Connect(function(desc)
    if desc:IsA("Humanoid") then
        untrackNPC(desc.Parent)
    end
end)

-- Run this for every player to handle them respawning automatically
local function monitorPlayer(player)
    if player == Players.LocalPlayer then return end
    
    -- Track current character
    if player.Character then
        _G.GraphicsEngine.createESPLabel(player)
    end
    
    -- Track all future respawns
    player.CharacterAdded:Connect(function()
        task.wait(0.5) -- Small safety delay to let joints/parts assemble
        _G.GraphicsEngine.createESPLabel(player)
    end)
end

-- Apply to current and new players
for _, p in ipairs(Players:GetPlayers()) do monitorPlayer(p) end
Players.PlayerAdded:Connect(monitorPlayer)

-- PART 4: Scaling Pipelines and Dynamic Rendering Loops
local utils = _G.CoreUtils
local mech = _G.Mechanics
local originalProps, npcHitboxes = _G.OriginalProps, _G.NpcHitboxes

_G.Pipeline = {
    applyToPlayer = function(player)
        if not player or not player.Character or player == utils.LocalPlayer then return end
        if not mech.shouldApplyHitbox(player) then 
            if originalProps[player] then mech.restorePlayer(player) end
            return 
        end
        local char = player.Character
        local hum = char:FindFirstChildOfClass("Humanoid")
        local isSitting = (hum and hum.SeatPart and (hum.SeatPart:IsA("VehicleSeat") or hum.SeatPart:IsA("Seat")))
        pcall(function()
            local actualTarget = isSitting and "Head" or _G.TargetPart
            local part = char:FindFirstChild(actualTarget) or char:FindFirstChild("HumanoidRootPart")
            if not part or not part:IsA("BasePart") then return end
            if originalProps[player] and not originalProps[player][part.Name] then mech.restorePlayer(player) end
            mech.storeOriginal(player, part.Name)
            local curSize = (part.Name == "HumanoidRootPart") and _G.RootSize or _G.HeadSize
            if _G.HitboxScaleMode == "Large" then curSize = curSize * 2.5 elseif _G.HitboxScaleMode == "Small" then curSize = curSize * 0.6 end
            utils.safeSetProperty(part, "Size", Vector3.new(curSize, curSize, curSize))
            utils.safeSetProperty(part, "Transparency", _G.HitboxTransparency)
            utils.safeSetProperty(part, "Material", Enum.Material.SmoothPlastic)
            utils.safeSetProperty(part, "CanCollide", false)
            utils.safeSetProperty(part, "CanTouch", true)
            if part.Name == "Head" then utils.safeSetProperty(part, "Massless", true) end
        end)
    end,
    applyToNPC = function(npc)
        if not npc then return end
        pcall(function()
            local part = npc:FindFirstChild("Head")
            if not part or not part:IsA("BasePart") then return end
            mech.storeNPCOriginal(npc, part.Name)
            local tSize = _G.HeadSize -- Synchronized with Head Slider Engine
            if _G.HitboxScaleMode == "Large" then tSize = tSize * 2.5 elseif _G.HitboxScaleMode == "Small" then tSize = tSize * 0.6 end
            utils.safeSetProperty(part, "Size", Vector3.new(tSize, tSize, tSize))
            utils.safeSetProperty(part, "Transparency", _G.HitboxTransparency)
            utils.safeSetProperty(part, "Material", Enum.Material.SmoothPlastic)
            utils.safeSetProperty(part, "CanCollide", false)
            utils.safeSetProperty(part, "CanTouch", true)
            utils.safeSetProperty(part, "Massless", true)
        end)
    end
}

