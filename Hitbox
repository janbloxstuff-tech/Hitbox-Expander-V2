-- JanBlox Gui Pro Version (LocalScript) - PART 1
-- Place this script in StarterGui (or PlayerScripts) so it runs for the LocalPlayer

-- Original settings from your script
_G.HeadSize = 5
_G.Disabled = true
_G.TargetPart = "HumanoidRootPart"
_G.NPCHitbox = false
_G.ESPEnabled = false
_G.ESPEnabled2D = false
_G.ShowTeamESP = false

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")
local Camera = Workspace.CurrentCamera

-- Store original properties
local originalProps = {}
local npcHitboxes = {}
local espHighlights = {}
local esp2DBoxes = {}
local playerLabels = {}
local trackedNPCs = {}

local npcScanCooldown = 0
local NPC_SCAN_INTERVAL = 1

local function storeOriginal(player, partName)
    if not player or not player.Character then return end
    if not originalProps[player] then originalProps[player] = {} end
    if originalProps[player][partName] then return end
    local part = player.Character:FindFirstChild(partName)
    if part and part:IsA("BasePart") then
        originalProps[player][partName] = {
            Size = part.Size,
            Transparency = part.Transparency,
            BrickColor = part.BrickColor,
            Material = part.Material,
            CanCollide = part.CanCollide,
        }
    end
end

local function storeNPCOriginal(npc, partName)
    if not npc then return end
    if not npcHitboxes[npc] then npcHitboxes[npc] = {} end
    if npcHitboxes[npc][partName] then return end
    local part = npc:FindFirstChild(partName)
    if part and part:IsA("BasePart") then
        npcHitboxes[npc][partName] = {
            Size = part.Size,
            Transparency = part.Transparency,
            BrickColor = part.BrickColor,
            Material = part.Material,
            CanCollide = part.CanCollide,
        }
    end
end

local function shouldApplyHitbox(player)
    if not _G.TeamCheck then return true end
    if not LocalPlayer or not LocalPlayer.Character then return false end
    return player.Team ~= LocalPlayer.Team
end

local function applyToPlayer(player)
    if not player or not player.Character then return end
    if player == LocalPlayer then return end
    if not shouldApplyHitbox(player) then return end
    
    pcall(function()
        local part = player.Character:FindFirstChild(_G.TargetPart)
        if not part or not part:IsA("BasePart") then
            part = player.Character:FindFirstChild("HumanoidRootPart")
            if not part then return end
        end

        storeOriginal(player, part.Name)
        part.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize)
        part.Transparency = 0.7
        part.BrickColor = BrickColor.new("Really blue")
        part.Material = Enum.Material.Neon
        part.CanCollide = false
    end)
end

local function applyToNPC(npc)
    if not npc then return end
    pcall(function()
        local part = npc:FindFirstChild("HumanoidRootPart")
        if not part then
            part = npc:FindFirstChild("Torso")
        end
        if not part then return end

        storeNPCOriginal(npc, part.Name)
        part.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize)
        part.Transparency = 0.7
        part.BrickColor = BrickColor.new("Really blue")
        part.Material = Enum.Material.Neon
        part.CanCollide = false
    end)
end

local function restorePlayer(player)
    if not player then return end
    local data = originalProps[player]
    if not data or not player.Character then
        originalProps[player] = nil
        return
    end

    for partName, props in pairs(data) do
        local part = player.Character:FindFirstChild(partName)
        if part and part:IsA("BasePart") and props then
            pcall(function()
                part.Size = props.Size
                part.Transparency = props.Transparency
                part.BrickColor = props.BrickColor
                part.Material = props.Material
                part.CanCollide = props.CanCollide
            end)
        end
    end

    originalProps[player] = nil
end

local function restoreNPC(npc)
    if not npc then return end
    local data = npcHitboxes[npc]
    if not data then return end

    for partName, props in pairs(data) do
        local part = npc:FindFirstChild(partName)
        if part and part:IsA("BasePart") and props then
            pcall(function()
                part.Size = props.Size
                part.Transparency = props.Transparency
                part.BrickColor = props.BrickColor
                part.Material = props.Material
                part.CanCollide = props.CanCollide
            end)
        end
    end

    npcHitboxes[npc] = nil
end

local function restorePlayerFully(player)
    if not player or not player.Character then return end
    
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    local head = player.Character:FindFirstChild("Head")
    
    if hrp and originalProps[player] and originalProps[player]["HumanoidRootPart"] then
        local props = originalProps[player]["HumanoidRootPart"]
        pcall(function()
            hrp.Size = props.Size
            hrp.Transparency = props.Transparency
            hrp.BrickColor = props.BrickColor
            hrp.Material = props.Material
            hrp.CanCollide = props.CanCollide
        end)
    end
    
    if head and originalProps[player] and originalProps[player]["Head"] then
        local props = originalProps[player]["Head"]
        pcall(function()
            head.Size = props.Size
            head.Transparency = props.Transparency
            head.BrickColor = props.BrickColor
            head.Material = props.Material
            head.CanCollide = props.CanCollide
        end)
    end
    
    originalProps[player] = nil
end

local function restoreAll()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            restorePlayer(player)
        end
    end
end

local function restoreAllNPCs()
    for npc, _ in pairs(npcHitboxes) do
        restoreNPC(npc)
    end
    trackedNPCs = {}
end

local function createESPHighlight(player)
    if espHighlights[player] then return end
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    
    pcall(function()
        local highlight = Instance.new("Highlight")
        highlight.Adornee = player.Character
        highlight.FillColor = Color3.fromRGB(255, 0, 0) -- RED
        highlight.OutlineColor = Color3.fromRGB(255, 0, 0) -- RED
        highlight.Parent = player.Character
        espHighlights[player] = highlight
    end)
end

local function removeESPHighlight(player)
    if espHighlights[player] then
        pcall(function()
            espHighlights[player]:Destroy()
        end)
        espHighlights[player] = nil
    end
end

local function create2DESP(player)
    if esp2DBoxes[player] then return end
    if not player.Character then return end
    
    pcall(function()
        local billboardGui = Instance.new("BillboardGui")
        billboardGui.Size = UDim2.new(4, 0, 5, 0)
        billboardGui.MaxDistance = math.huge
        billboardGui.Name = "ESP2D_" .. player.Name
        billboardGui.Parent = player.Character:FindFirstChild("Head") or player.Character:FindFirstChild("HumanoidRootPart")
        
        local frame = Instance.new("Frame")
        frame.BackgroundTransparency = 0.3
        frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        frame.BorderSizePixel = 2
        frame.BorderColor3 = Color3.fromRGB(255, 0, 0)
        frame.Size = UDim2.new(1, 0, 1, 0)
        frame.Parent = billboardGui
        
        esp2DBoxes[player] = {gui = billboardGui, frame = frame}
    end)
end

local function removeESP2D(player)
    if esp2DBoxes[player] then
        pcall(function()
            esp2DBoxes[player].gui:Destroy()
        end)
        esp2DBoxes[player] = nil
    end
end

local function createESPLabel(player)
    if playerLabels[player] then return end
    if not player.Character then return end
    
    pcall(function()
        local billboardGui = Instance.new("BillboardGui")
        billboardGui.Size = UDim2.new(4, 0, 2, 0)
        billboardGui.MaxDistance = math.huge
        billboardGui.Name = "ESPLabel_" .. player.Name
        billboardGui.Parent = player.Character:FindFirstChild("Head") or player.Character:FindFirstChild("HumanoidRootPart")
        
        local textLabel = Instance.new("TextLabel")
        textLabel.BackgroundTransparency = 0.3
        textLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.Font = Enum.Font.GothamBold
        textLabel.TextSize = 14
        textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        textLabel.TextStrokeTransparency = 0.5
        textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        textLabel.Parent = billboardGui
        
        playerLabels[player] = {gui = billboardGui, label = textLabel}
    end)
end

local function removeESPLabel(player)
    if playerLabels[player] then
        pcall(function()
            playerLabels[player].gui:Destroy()
        end)
        playerLabels[player] = nil
    end
end

local function updateESPLabel(player)
    if not playerLabels[player] or not player.Character then return end
    
    local humanoid = player.Character:FindFirstChild("Humanoid")
    
    if humanoid then
        local health = humanoid.Health
        local healthText = health > 0 and math.floor(health) or "DEAD"
        playerLabels[player].label.Text = player.Name .. " | Health: " .. healthText
        
        if health <= 0 then
            playerLabels[player].label.TextColor3 = Color3.fromRGB(255, 0, 0)
        else
            playerLabels[player].label.TextColor3 = Color3.fromRGB(255, 255, 255)
        end
    end
end

local function shouldShowESP(player)
    if player == LocalPlayer then return false end
    if not _G.TeamCheck then return _G.ESPEnabled end
    if _G.ShowTeamESP then return true end
    return player.Team ~= LocalPlayer.Team and _G.ESPEnabled
end

-- Reapply or restore on CharacterAdded
Players.PlayerAdded:Connect(function(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function()
        originalProps[player] = nil
        wait(0.1)
        if _G.Disabled then
            applyToPlayer(player)
        end
        if shouldShowESP(player) then
            createESPHighlight(player)
            createESPLabel(player)
            if _G.ESPEnabled2D then
                create2DESP(player)
            end
        end
    end)
end)

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        player.CharacterAdded:Connect(function()
            originalProps[player] = nil
            wait(0.1)
            if _G.Disabled then applyToPlayer(player) end
            if shouldShowESP(player) then
                createESPHighlight(player)
                createESPLabel(player)
                if _G.ESPEnabled2D then
                    create2DESP(player)
                end
            end
        end)
        if player.Character and _G.Disabled then
            applyToPlayer(player)
        end
        if shouldShowESP(player) then
            createESPHighlight(player)
            createESPLabel(player)
            if _G.ESPEnabled2D then
                create2DESP(player)
            end
        end
    end
end

-- OPTIMIZED RenderStepped loop
RunService.RenderStepped:Connect(function()
    -- Update ESP labels (passes through)
    for player, labelData in pairs(playerLabels) do
        if player and player.Character then
            updateESPLabel(player)
        end
    end
    
    if _G.Disabled then
        -- Apply to players (every frame)
        for _, v in next, Players:GetPlayers() do
            if v ~= LocalPlayer and v.Character then
                local humanoid = v.Character:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health <= 0 then
                    restorePlayerFully(v)
                    if espHighlights[v] then
                        removeESPHighlight(v)
                    end
                else
                    applyToPlayer(v)
                end
            end
        end

        -- Scan NPCs ONLY every 1 second
        npcScanCooldown = npcScanCooldown + (1/60)
        if npcScanCooldown >= NPC_SCAN_INTERVAL and _G.NPCHitbox then
            npcScanCooldown = 0
            
            pcall(function()
                for _, npc in ipairs(Workspace:GetChildren()) do
                    if npc:IsA("Model") and npc ~= LocalPlayer.Character and npc.Parent == Workspace then
                        local humanoid = npc:FindFirstChild("Humanoid")
                        local isPlayer = Players:FindFirstChild(npc.Name)
                        
                        if humanoid and not isPlayer then
                            if not trackedNPCs[npc] then
                                trackedNPCs[npc] = true
                            end
                            
                            if humanoid.Health > 0 then
                                applyToNPC(npc)
                            else
                                restoreNPC(npc)
                            end
                        end
                    end
                end
            end)
        end
    else
        restoreAll()
        restoreAllNPCs()
    end
end)

