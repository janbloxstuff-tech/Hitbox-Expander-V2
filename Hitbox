local function updateESPLabel(player)
    if not playerLabels[player] or not player.Character then return end
    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
    local healthText = (humanoid and humanoid.Health > 0) and tostring(math.floor(humanoid.Health)) or "DEAD"
    local displayText = ""
    if _G.ShowName then displayText = player.DisplayName end
    if _G.ShowHealth then displayText = displayText ~= "" and (displayText .. " [" .. healthText .. "]") or ("[" .. healthText .. "]") end
    playerLabels[player].label.Text = displayText
    playerLabels[player].label.TextColor3 = (healthText == "DEAD") and Color3.fromRGB(255, 0, 0) or utils.getTeamColor(player)
end

local function updateNPCLabel(npc)
    if not npcLabels[npc] or not npc.Parent then return end
    local humanoid = npc:FindFirstChildOfClass("Humanoid")
    local healthText = (humanoid and humanoid.Health > 0) and tostring(math.floor(humanoid.Health)) or "0"
    npcLabels[npc].label.Text = npc.Name .. " [" .. healthText .. "]"
end

local function connectCharacter(p)
    p.CharacterAdded:Connect(function(char)
        mech.restorePlayer(p)
        graphics.removeESPLabel(p); graphics.removeESPHighlight(p)
        char:WaitForChild("HumanoidRootPart", 5); char:WaitForChild("Humanoid", 5); task.wait(0.5)
        if _G.Disabled then pipeline.applyToPlayer(p) end
        globalESPUpdate()
    end)
    p:GetPropertyChangedSignal("Team"):Connect(function() task.wait(0.2); globalESPUpdate() end)
end

Players.PlayerAdded:Connect(connectCharacter)
for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then connectCharacter(p); if p.Character then globalESPUpdate() end end end

local npcScanCooldown = 0
RunService.RenderStepped:Connect(function()
    if _G.InventoryLock then pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, true) end) end

    if _G.PlayerModEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
        local myHumanoid = LocalPlayer.Character.Humanoid
        myHumanoid.UseJumpPower = true 
        if myHumanoid.WalkSpeed ~= _G.CustomWalkSpeed then myHumanoid.WalkSpeed = _G.CustomWalkSpeed end
        if myHumanoid.JumpPower ~= _G.CustomJumpPower then myHumanoid.JumpPower = _G.CustomJumpPower end
    end

    for p, _ in pairs(playerLabels) do if p then updateESPLabel(p) end end
    for npc, _ in pairs(npcLabels) do if npc then updateNPCLabel(npc) end end
    
    if _G.Disabled then
        for _, v in next, Players:GetPlayers() do
            if v ~= LocalPlayer and v.Character then
                local hum = v.Character:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health <= 0 then 
                    mech.restorePlayer(v) 
                    graphics.removeESPHighlight(v) 
                else 
                    -- Optimize: Only apply the size configuration if it changed
                    local targetName = (_G.TargetPart == "Head" or (hum and hum.SeatPart)) and "Head" or "HumanoidRootPart"
                    local part = v.Character:FindFirstChild(targetName)
                    local desiredSize = (targetName == "HumanoidRootPart") and _G.RootSize or _G.HeadSize
                    if _G.HitboxScaleMode == "Large" then desiredSize = desiredSize * 2.5 elseif _G.HitboxScaleMode == "Small" then desiredSize = desiredSize * 0.6 end
                    
                    if part and part.Size.X ~= desiredSize then
                        pipeline.applyToPlayer(v) 
                    end
                end
            end
        end
        
        npcScanCooldown = npcScanCooldown + (1/60)
        if npcScanCooldown >= 2.0 then
            npcScanCooldown = 0
            pcall(function()
                local newNpcFound = false
                for _, object in ipairs(Workspace:GetDescendants()) do
                    if object:IsA("Model") and object ~= LocalPlayer.Character then
                        local hum = object:FindFirstChildOfClass("Humanoid")
                        if hum and not Players:FindFirstChild(object.Name) then
                            if not trackedNPCs[object] then
                                trackedNPCs[object] = true
                                newNpcFound = true
                            end
                            
                            local head = object:FindFirstChild("Head")
                            local desiredNPCSize = 5
                            if _G.HitboxScaleMode == "Large" then desiredNPCSize = 12.5 elseif _G.HitboxScaleMode == "Small" then desiredNPCSize = 3 end
                            
                            if _G.NPCHitbox and hum.Health > 0 then 
                                if head and head.Size.X ~= desiredNPCSize then
                                    pipeline.applyToNPC(object) 
                                end
                            else 
                                if _G.NpcHitboxes[object] then mech.restoreNPC(object) end
                            end
                        end
                    end
                end
                if newNpcFound then globalESPUpdate() end
            end)
        end
    else
        mech.restoreAll() mech.restoreAllNPCs()
    end
end)
