	warn(string.format("[%s] - %s - %s", os.date("%X"), self.WARN, tostring(msg)))
end

-- Core Utility Math Implementations
local MathUtils = {}
function MathUtils.clamp(val, min, max)
	if val < min then return min end
	if val > max then return max end
	return val
end

function MathUtils.lerp(start, stop, amt)
	return start + (stop - start) * amt
end

function MathUtils.round(num, numDecimalPlaces)
	local mult = 10^(numDecimalPlaces or 0)
	return math.floor(num * mult + 0.5) / mult
end

-- Core Property Safe-Set Methods
local function safeSetProperty(instance, property, value)
	if not instance or not instance:IsDescendantOf(game) then return false end
	local success, err = pcall(function()
		instance[property] = value
	end)
	if not success then
		Logger:Warn("Failed to set property " .. tostring(property) .. " on object: " .. tostring(err))
	end
	return success
end

local function safeGetProperty(instance, property)
	if not instance then return nil end
	local success, result = pcall(function()
		return instance[property]
	end)
	if success then return result else return nil end
end

local function hasForceField(character)
	if not character then return false end
	return character:FindFirstChildOfClass("ForceField") ~= nil
end

local function getTeamColor(player)
	if player and player.Team then 
		return player.TeamColor.Color 
	end
	return Color3.fromRGB(255, 255, 255)
end

