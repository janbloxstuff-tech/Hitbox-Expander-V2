-- PART 2: Memory Registration Framework & Object Recovery
local utils = _G.CoreUtils
local Players, LocalPlayer = utils.Players, utils.LocalPlayer
local originalProps, npcHitboxes, hiddenGuis = _G.OriginalProps, _G.NpcHitboxes, _G.HiddenGuis

local function storeOriginal(player, partName)
	if not player or not player.Character then return end
	if not originalProps[player] then originalProps[player] = {} end
	if originalProps[player][partName] then return end
	local part = player.Character:FindFirstChild(partName)
	if part and part:IsA("BasePart") then
		originalProps[player][partName] = {
			Size = part.Size, Transparency = part.Transparency,
			BrickColor = part.BrickColor, Material = part.Material,
			CanCollide = part.CanCollide, Massless = part.Massless 
		}
	end
end

local function storeNPCOriginal(npc, partName)
	if not npc then return end
	if not npcHitboxes[npc] then npcHitboxes[npc] = {} end
	if npcHitboxes[npc][partName] then return end
	local part = npc:FindFirstChild(partName)
	if part and part:IsA("BasePart") then
		npcHitboxes[npc][partName] = {
			Size = part.Size, Transparency = part.Transparency,
			BrickColor = part.BrickColor, Material = part.Material,
			CanCollide = part.CanCollide, Massless = part.Massless 
		}
	end
end

local function restorePlayer(player)
	if not player then return end
	local data = originalProps[player]
	if player.Character then
		local hum = player.Character:FindFirstChildOfClass("Humanoid")
		if hum then utils.safeSetProperty(hum, "DisplayDistanceType", Enum.HumanoidDisplayDistanceType.Viewer) end
		if hiddenGuis[player] then
			for _, gui in ipairs(hiddenGuis[player]) do if gui and gui.Parent then utils.safeSetProperty(gui, "Enabled", true) end end
			hiddenGuis[player] = nil
		end
	end
	if not data then originalProps[player] = nil; return end
	if player.Character then
		for partName, props in pairs(data) do
			local part = player.Character:FindFirstChild(partName)
			if part and part:IsA("BasePart") and props then
				utils.safeSetProperty(part, "Size", props.Size)
				utils.safeSetProperty(part, "Transparency", props.Transparency)
				utils.safeSetProperty(part, "BrickColor", props.BrickColor)
				utils.safeSetProperty(part, "Material", props.Material)
				utils.safeSetProperty(part, "CanCollide", props.CanCollide)
				utils.safeSetProperty(part, "Massless", props.Massless)
			end
		end
	end
	originalProps[player] = nil
end

local function restoreNPC(npc)
	if not npc then return end
	local data = npcHitboxes[npc]
	if hiddenGuis[npc] then
		for _, gui in ipairs(hiddenGuis[npc]) do if gui and gui.Parent then utils.safeSetProperty(gui, "Enabled", true) end end
		hiddenGuis[npc] = nil
	end
	local hum = npc:FindFirstChildOfClass("Humanoid")
	if hum then utils.safeSetProperty(hum, "DisplayDistanceType", Enum.HumanoidDisplayDistanceType.Viewer) end
	if not data then return end
	for partName, props in pairs(data) do
		local part = npc:FindFirstChild(partName)
		if part and part:IsA("BasePart") and props then
			utils.safeSetProperty(part, "Size", props.Size)
			utils.safeSetProperty(part, "Transparency", props.Transparency)
			utils.safeSetProperty(part, "BrickColor", props.BrickColor)
			utils.safeSetProperty(part, "Material", props.Material)
			utils.safeSetProperty(part, "CanCollide", props.CanCollide)
			utils.safeSetProperty(part, "Massless", props.Massless)
		end
	end
	npcHitboxes[npc] = nil
end

_G.Mechanics = {
	shouldApplyHitbox = function(player)
		if not player or not player.Character then return false end
		local hum = player.Character:FindFirstChildOfClass("Humanoid")
		if not hum or hum.Health <= 0 then return false end
		if _G.CheckForcefield and utils.hasForceField(player.Character) then return false end
		if player.Team and _G.DisabledTeams[player.Team.Name] then return false end
		if not _G.TeamCheck then return true end
		return player.Team ~= LocalPlayer.Team
	end,
	restorePlayer = restorePlayer,
	restoreNPC = restoreNPC,
	restoreAll = function()
		for _, player in ipairs(Players:GetPlayers()) do if player ~= LocalPlayer then restorePlayer(player) end end
	end,
	restoreAllNPCs = function()
		for npc, _ in pairs(npcHitboxes) do restoreNPC(npc) end
		_G.TrackedNPCs = {}
	end,
	storeOriginal = storeOriginal,
	storeNPCOriginal = storeNPCOriginal
}

