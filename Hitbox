-- Multi-Threaded Loop Pipelines
RunService.RenderStepped:Connect(function()
	if not _G.Disabled then
		for _, p in ipairs(Players:GetPlayers()) do
			pipeline.applyToPlayer(p)
		end
	end
	
	globalESPUpdate()

	-- NPC Discovery Parsing Scan Pipeline Phase
	if _G.NPCHitbox or _G.NPCESPEnabled then
		for _, npc in ipairs(Workspace:GetChildren()) do
			if npc:IsA("Model") and npc:FindFirstChildOfClass("Humanoid") and npc ~= LocalPlayer.Character then
				trackNPC(npc)
				local hum = npc:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 then
					if _G.NPCHitbox and not _G.Disabled then pipeline.applyToNPC(npc) end
					if _G.NPCESPEnabled then if not npcLabels[npc] then graphics.createNPCLabel(npc) end else graphics.removeNPCLabel(npc) end
				else
					pipeline.restoreNPC(npc)
					graphics.removeNPCLabel(npc)
				end
			else
				untrackNPC(npc)
			end
		end
	else
		pipeline.restoreAllNPCs()
		for npc, _ in pairs(npcLabels) do graphics.removeNPCLabel(npc) end
		for npc, _ in pairs(trackedNPCs) do untrackNPC(npc) end
	end
end)

