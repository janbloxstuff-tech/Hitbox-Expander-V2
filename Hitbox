-- Runtime Pipeline Synchronization
local function globalESPUpdate()
	if _G.Disabled then return end
	for _, p in ipairs(utils.Players:GetPlayers()) do
		if p ~= utils.LocalPlayer then
			if _G.ESPEnabled and mech.shouldApplyHitbox(p) then
				graphics.createESPHighlight(p)
				graphics.createESPLabel(p)
			else
				graphics.removeESPHighlight(p)
				graphics.removeESPLabel(p)
			end
		end
	end
end

utils.RunService.Heartbeat:Connect(function()
	if _G.Disabled then return end
	for _, p in ipairs(utils.Players:GetPlayers()) do
		if p ~= utils.LocalPlayer then
			pipeline.applyToPlayer(p)
			if _G.ESPEnabled and mech.shouldApplyHitbox(p) then
				if not _G.PlayerLabels[p] then graphics.createESPLabel(p) end
				if not _G.EspHighlights[p] then graphics.createESPHighlight(p) end
			end
		end
	end

	if _G.NPCHitbox or _G.NPCESPEnabled then
		for npc, _ in pairs(_G.TrackedNPCs) do
			if npc and npc.Parent then
				local hum = npc:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 then
					if _G.NPCHitbox then pipeline.applyToNPC(npc) end
					if _G.NPCESPEnabled then if not _G.NpcLabels[npc] then graphics.createNPCLabel(npc) end else graphics.removeNPCLabel(npc) end
				else
					mech.restoreNPC(npc)
					graphics.removeNPCLabel(npc)
				end
			else
				untrackNPC(npc)
			end
		end
	else
		mech.restoreAllNPCs()
		for npc, _ in pairs(_G.NpcLabels) do graphics.removeNPCLabel(npc) end
		for npc, _ in pairs(_G.TrackedNPCs) do untrackNPC(npc) end
	end
end)

utils.Players.PlayerAdded:Connect(function(p)
	p.CharacterAdded:Connect(function(char)
		task.spawn(function() char:WaitForChild("HumanoidRootPart", 3) globalESPUpdate() end)
	end)
	p:GetPropertyChangedSignal("Team"):Connect(function() task.wait(0.1); globalESPUpdate() end)
end)

local function connectPlayerSignals(p)
	local function setupChar(char)
		graphics.removeESPHighlight(p); graphics.removeESPLabel(p)
		local head = char:WaitForChild("Head", 5)
		if head then task.wait(0.05) globalESPUpdate() end
	end
	if p.Character then task.spawn(setupChar, p.Character) end
	p.CharacterAdded:Connect(setupChar)
	p:GetPropertyChangedSignal("Team"):Connect(function() task.wait(0.05); globalESPUpdate() end)
end

for _, p in ipairs(utils.Players:GetPlayers()) do
	if p ~= utils.LocalPlayer then connectPlayerSignals(p) end
end
utils.Players.PlayerAdded:Connect(connectPlayerSignals)
