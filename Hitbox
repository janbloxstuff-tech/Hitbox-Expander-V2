-- Hitbox Processing Engine and Player Recovery Framework

local utils = _G.CoreUtils
local Players, RunService, Workspace, LocalPlayer = utils.Players, utils.RunService, utils.Workspace, utils.LocalPlayer
local originalProps, npcHitboxes = _G.OriginalProps, _G.NpcHitboxes
local espHighlights, playerLabels, npcLabels, trackedNPCs, hiddenGuis = _G.EspHighlights, _G.PlayerLabels, _G.NpcLabels, _G.TrackedNPCs, _G.HiddenGuis

local function shouldApplyHitbox(player)
    if _G.CheckForcefield and player.Character and utils.hasForceField(player.Character) then return false end
    if player.Team and _G.DisabledTeams[player.Team.Name] then return false end
    if not _G.TeamCheck then return true end
    if not LocalPlayer or not LocalPlayer.Character then return false end
    return player.Team ~= LocalPlayer.Team
end

local function restorePlayer(player)
    if not player then return end
    local data = originalProps[player]
    
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then utils.safeSetProperty(hum, "DisplayDistanceType", Enum.HumanoidDisplayDistanceType.Viewer) end
        
        if hiddenGuis[player] then
            for _, gui in ipairs(hiddenGuis[player]) do
                if gui and gui.Parent then utils.safeSetProperty(gui, "Enabled", true) end
            end
            hiddenGuis[player] = nil
        end
    end

    if not data then
        originalProps[player] = nil
        return
    end
    
    if player.Character then
        for partName, props in pairs(data) do
            local part = player.Character:FindFirstChild(partName)
            if part and part:IsA("BasePart") and props then
                utils.safeSetProperty(part, "Size", props.Size)
                utils.safeSetProperty(part, "Transparency", props.Transparency)
                utils.safeSetProperty(part, "BrickColor", props.BrickColor)
                utils.safeSetProperty(part, "Material", props.Material)
                utils.safeSetProperty(part, "CanCollide", props.CanCollide)
                utils.safeSetProperty(part, "Massless", props.Massless)
            end
        end
    end
    originalProps[player] = nil
end

local function restoreNPC(npc)
    if not npc then return end
    local data = npcHitboxes[npc]
    
    if hiddenGuis[npc] then
        for _, gui in ipairs(hiddenGuis[npc]) do
            if gui and gui.Parent then utils.safeSetProperty(gui, "Enabled", true) end
        end
        hiddenGuis[npc] = nil
    end
    local hum = npc:FindFirstChildOfClass("Humanoid")
    if hum then utils.safeSetProperty(hum, "DisplayDistanceType", Enum.HumanoidDisplayDistanceType.Viewer) end

    if not data then return end
    for partName, props in pairs(data) do
        local part = npc:FindFirstChild(partName)
        if part and part:IsA("BasePart") and props then
            utils.safeSetProperty(part, "Size", props.Size)
            utils.safeSetProperty(part, "Transparency", props.Transparency)
            utils.safeSetProperty(part, "BrickColor", props.BrickColor)
            utils.safeSetProperty(part, "Material", props.Material)
            utils.safeSetProperty(part, "CanCollide", props.CanCollide)
            utils.safeSetProperty(part, "Massless", props.Massless)
        end
    end
    npcHitboxes[npc] = nil
end

local function handleExternalGuis(instance, lookupKey)
    if not instance then return end
    if not hiddenGuis[lookupKey] then hiddenGuis[lookupKey] = {} end
    
    for _, desc in ipairs(instance:GetDescendants()) do
        if desc:IsA("BillboardGui") and not string.find(desc.Name, "ESPLabel_") and not string.find(desc.Name, "NPCESP_") then
            table.insert(hiddenGuis[lookupKey], desc)
            utils.safeSetProperty(desc, "Enabled", false)
        end
    end
end

_G.Mechanics = {
    shouldApplyHitbox = shouldApplyHitbox,
    restorePlayer = restorePlayer,
    restoreNPC = restoreNPC,
    handleExternalGuis = handleExternalGuis,
    restoreAll = function()
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then restorePlayer(player) end
        end
    end,
    restoreAllNPCs = function()
        for npc, _ in pairs(npcHitboxes) do restoreNPC(npc) end
        _G.TrackedNPCs = {}
    end
}

