espTeamToggleButton.MouseButton1Click:Connect(function()
    _G.ShowTeamESP = not _G.ShowTeamESP
    espTeamToggleButton.Text = "Toggle Team ESP: " .. (_G.ShowTeamESP and "ON" or "OFF")
    
    if _G.ShowTeamESP and _G.ESPEnabled then
        for _, p in ipairs(Players:GetPlayers()) do
