-- Core Rebuild Logic preserving names precisely to avoid loop worker crashes
local isJumpscaring = false

local function updateJumpscareMenu()
	for _, v in ipairs(jumpscareDropFrame:GetChildren()) do
		if not v:IsA("UIListLayout") then v:Destroy() end
	end
	local order = 1
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			createPlayerRow(
				jumpscareDropFrame,
				p.DisplayName,
				p.DisplayName .. " (" .. p.Name .. ")",
				order,
				Color3.fromRGB(80, 40, 40),
				"Jumpscare",
				function()
					if isJumpscaring then return end
					local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
					local tRoot = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
					if myRoot and tRoot then
						isJumpscaring = true
						local oldC = myRoot.CFrame
						myRoot.CFrame = tRoot.CFrame * CFrame.new(0, 0, -3) * CFrame.Angles(0, math.pi, 0)
						task.wait(0.1)
						myRoot.CFrame = oldC
						isJumpscaring = false
					end
				end
			)
			order = order + 1
		end
	end
	if jumpscareDropFrame.Visible then
		jumpscareDropFrame.Size = UDim2.new(1, 0, 0, jumpscareLayout.AbsoluteContentSize.Y)
	end
end

local function updateTeleportMenu()
	for _, v in ipairs(teleportDropFrame:GetChildren()) do
		if not v:IsA("UIListLayout") then v:Destroy() end
	end
	local order = 1
	local grouped = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			local tName = p.Team and p.Team.Name or "Neutral"
			if not grouped[tName] then grouped[tName] = {} end
			table.insert(grouped[tName], p)
		end
	end

	for tName, players in pairs(grouped) do
		local teamHeader = Instance.new("TextLabel")
		teamHeader.Size = UDim2.new(1, 0, 0, 24)
		teamHeader.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
		teamHeader.TextColor3 = Color3.fromRGB(255, 255, 100)
		teamHeader.Font = Enum.Font.GothamBold
		teamHeader.TextSize = 11
		teamHeader.Text = "Team: " .. tName
		teamHeader.LayoutOrder = order
		teamHeader.ZIndex = 14
		teamHeader.Parent = teleportDropFrame
		order = order + 1

		for _, p in ipairs(players) do
			local dText = "[Calculating...]"
			if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				local dist = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude)
				dText = "[" .. dist .. " Studs]"
			end

			createPlayerRow(
				teleportDropFrame,
				p.DisplayName,
				p.DisplayName .. " " .. dText,
				order,
				Color3.fromRGB(50, 50, 50),
				"Teleport",
				function()
					if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
						LocalPlayer.Character.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame + Vector3.new(0, 2, 0)
					end
				end
			)
			local children = teleportDropFrame:GetChildren()
			local last = children[#children]
			if last and last:IsA("Frame") then
				last:SetAttribute("TargetPlayer", p.Name)
				last:SetAttribute("BaseName", p.DisplayName)
			end
			order = order + 1
		end
	end
	if teleportDropFrame.Visible then
		teleportDropFrame.Size = UDim2.new(1, 0, 0, teleportDropLayout.AbsoluteContentSize.Y)
	end
end

local function refreshTeamDropdown()
	for _, v in ipairs(teamDropFrame:GetChildren()) do
		if not v:IsA("UIListLayout") then v:Destroy() end
	end
	local order = 1
	for _, team in ipairs(Teams:GetTeams()) do
		local active = _G.DisabledTeams[team.Name] and " [Bypassed]" or " [Monitored]"
		createPlayerRow(
			teamDropFrame,
			team.Name,
			team.Name .. active,
			order,
			_G.DisabledTeams[team.Name] and Color3.fromRGB(120, 50, 50) or Color3.fromRGB(50, 120, 50),
			_G.DisabledTeams[team.Name] and "Enable" or "Disable",
			function()
				_G.DisabledTeams[team.Name] = not _G.DisabledTeams[team.Name]
				refreshTeamDropdown()
			end
		)
		order = order + 1
	end
	if teamDropFrame.Visible then
		teamDropFrame.Size = UDim2.new(1, 0, 0, teamDropLayout.AbsoluteContentSize.Y)
	end
end

