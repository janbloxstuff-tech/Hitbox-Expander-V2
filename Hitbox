local globalESPUpdate = function() end 

-- Event-driven Hitbox Cleaner to instantly remove scaling upon player death (Fixes visual flicker)
local function cleanupHitboxInstantly(player, char)
	if char then
		local hrp = char:FindFirstChild(_G.TargetPart)
		local head = char:FindFirstChild("Head")
		
		-- Instantly revert modified parts before engine respawn changes states
		if hrp and originalSizes[player] and originalSizes[player].Root then
			hrp.Size = originalSizes[player].Root.Size
			hrp.Transparency = originalSizes[player].Root.Transparency
			hrp.Color = originalSizes[player].Root.Color
			hrp.Material = originalSizes[player].Root.Material
			hrp.CanCollide = originalSizes[player].Root.CanCollide
		end
		
		if head and originalSizes[player] and originalSizes[player].Head then
			head.Size = originalSizes[player].Head.Size
			head.Transparency = originalSizes[player].Head.Transparency
		end
	end
	if originalSizes[player] then originalSizes[player] = nil end
end

local pipeline = {
	applyToPlayer = function(p)
		if p == LocalPlayer or not p.Character then return end
		local char = p.Character
		
		-- Instant death handler checking to bypass flicker frame window
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum and hum.Health <= 0 then
			cleanupHitboxInstantly(p, char)
			return
		end
		
		local target = char:FindFirstChild(_G.TargetPart)
		local head = char:FindFirstChild("Head")

		if _G.TeamCheck and p.Team == LocalPlayer.Team then
			pipeline.restorePlayer(p)
			return
		end

		if _G.CheckForcefield and char:FindFirstChildOfClass("ForceField") then
			pipeline.restorePlayer(p)
			return
		end

		if not originalSizes[p] then
			originalSizes[p] = {
				Root = target and {
					Size = target.Size,
					Transparency = target.Transparency,
					Color = target.Color,
					Material = target.Material,
					CanCollide = target.CanCollide
				} or nil,
				Head = head and {
					Size = head.Size,
					Transparency = head.Transparency
				} or nil
			}
		end

		if not _G.Disabled then
			if target and target:IsA("BasePart") then
				target.Size = Vector3.new(_G.RootSize, _G.RootSize, _G.RootSize)
				target.Transparency = _G.HitboxTransparency
				target.Color = Color3.fromRGB(0, 180, 216)
				target.Material = Enum.Material.Neon
				target.CanCollide = false
			end
			if head and head:IsA("BasePart") then
				head.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize)
				head.Transparency = _G.HitboxTransparency
			end
		else
			pipeline.restorePlayer(p)
		end
	end,

	restorePlayer = function(p)
		if originalSizes[p] and p.Character then
			local char = p.Character
			local target = char:FindFirstChild(_G.TargetPart)
			local head = char:FindFirstChild("Head")
			
			if target and originalSizes[p].Root then
				local r = originalSizes[p].Root
				target.Size = r.Size
				target.Transparency = r.Transparency
				target.Color = r.Color
				target.Material = r.Material
				target.CanCollide = r.CanCollide
			end
			if head and originalSizes[p].Head then
				head.Size = originalSizes[p].Head.Size
				head.Transparency = originalSizes[p].Head.Transparency
			end
		end
	end,

	applyToNPC = function(npc)
		if not npc:IsA("Model") then return end
		
		local hum = npc:FindFirstChildOfClass("Humanoid")
		if hum and hum.Health <= 0 then
			pipeline.restoreNPC(npc)
			return
		end
		
		local target = npc:FindFirstChild(_G.TargetPart) or npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head")
		if not target then return end

		if not originalNPCSizes[npc] then
			originalNPCSizes[npc] = {
				Size = target.Size,
				Transparency = target.Transparency,
				Color = target.Color,
				Material = target.Material,
				CanCollide = target.CanCollide
			}
		end

		if _G.NPCHitbox and not _G.Disabled then
			target.Size = Vector3.new(_G.RootSize, _G.RootSize, _G.RootSize)
			target.Transparency = _G.HitboxTransparency
			target.Color = Color3.fromRGB(230, 57, 70)
			target.Material = Enum.Material.Neon
			target.CanCollide = false
		else
			pipeline.restoreNPC(npc)
		end
	end,

	restoreNPC = function(npc)
		if originalNPCSizes[npc] then
			local target = npc:FindFirstChild(_G.TargetPart) or npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head")
			if target then
				local o = originalNPCSizes[npc]
				target.Size = o.Size
				target.Transparency = o.Transparency
				target.Color = o.Color
				target.Material = o.Material
				target.CanCollide = o.CanCollide
			end
		end
	end,

	restoreAllPlayers = function()
		for p, _ in pairs(originalSizes) do pipeline.restorePlayer(p) end
		originalSizes = {}
	end,

	restoreAllNPCs = function()
		for npc, _ in pairs(originalNPCSizes) do pipeline.restoreNPC(npc) end
		originalNPCSizes = {}
	end
}

