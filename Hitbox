-- Button behaviors
toggleButton.MouseButton1Click:Connect(function()
    -- Toggle according to your original pattern: when _G.Disabled == true, the hitbox is active.
    _G.Disabled = not _G.Disabled

    if not _G.Disabled then
        -- turning hitbox OFF -> restore everything
        restoreAll()
        restoreAllNPCs()
    else
        -- turning hitbox ON -> apply to all players (will store originals)
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                applyToPlayer(p)
            end
        end
        -- Apply to NPCs if enabled
        if _G.NPCHitbox then
            for _, npc in ipairs(Workspace:GetDescendants()) do
                if npc:IsA("Model") and npc ~= LocalPlayer.Character then
                    local humanoid = npc:FindFirstChild("Humanoid")
                    if humanoid and not Players:FindFirstChild(npc.Name) then
                        applyToNPC(npc)
                    end
                end
            end
        end
    end
end)

changeButton.MouseButton1Click:Connect(function()
    -- Switch between HumanoidRootPart and Head
    -- before switching, restore previous changes so we don't leave modified parts behind
    restoreAll()
    if _G.TargetPart == "HumanoidRootPart" then
        _G.TargetPart = "Head"
    else
        _G.TargetPart = "HumanoidRootPart"
    end
    
    -- Update label
    targetLabel.Text = "Hitbox: " .. _G.TargetPart
    
    -- If currently enabled, apply to new target immediately
    if _G.Disabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                applyToPlayer(p)
            end
        end
    end
end)

npcToggleButton.MouseButton1Click:Connect(function()
    _G.NPCHitbox = not _G.NPCHitbox
    
    if _G.NPCHitbox then
        npcToggleButton.Text = "NPC Hitbox: ON"
        -- Only apply if main hitbox is enabled
        if _G.Disabled then
            for _, npc in ipairs(Workspace:GetDescendants()) do
                if npc:IsA("Model") and npc ~= LocalPlayer.Character then
                    local humanoid = npc:FindFirstChild("Humanoid")
                    if humanoid and not Players:FindFirstChild(npc.Name) then
                        applyToNPC(npc)
                    end
                end
            end
        end
    else
        npcToggleButton.Text = "NPC Hitbox: OFF"
        restoreAllNPCs()
    end
end)

minusButton.MouseButton1Click:Connect(function()
    -- Decrease size by 5, minimum is 5
    if _G.HeadSize > 5 then
        _G.HeadSize = _G.HeadSize - 5
    end
    
    sizeDisplay.Text = tostring(_G.HeadSize)
    
    -- If hitbox is currently enabled, reapply to all players and NPCs
    if _G.Disabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                applyToPlayer(p)
            end
        end
        if _G.NPCHitbox then
            for npc, _ in pairs(npcHitboxes) do
                applyToNPC(npc)
            end
        end
    end
end)

plusButton.MouseButton1Click:Connect(function()
    -- Increase size by 5, maximum is 50
    if _G.HeadSize < 50 then
        _G.HeadSize = _G.HeadSize + 5
    end
    
    sizeDisplay.Text = tostring(_G.HeadSize)
    
    -- If hitbox is currently enabled, reapply to all players and NPCs
    if _G.Disabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                applyToPlayer(p)
            end
        end
        if _G.NPCHitbox then
            for npc, _ in pairs(npcHitboxes) do
                applyToNPC(npc)
            end
        end
    end
end)
