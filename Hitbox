					if _G.TeamCheck and p.Team == LocalPlayer.Team then graphics.removeESPHighlight(p) else graphics.createESPHighlight(p) end
				end
			end
		end
		if _G.ESPEnabledText then
			for _, p in ipairs(Players:GetPlayers()) do
