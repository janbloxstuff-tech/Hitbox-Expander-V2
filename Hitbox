_G.FlingEngine = {
	fling = function(targetName)
		if targetName == "" then return end
		local targetPlayer = nil
		local search = string.lower(targetName)

		for _, p in ipairs(utils.Players:GetPlayers()) do
			if string.find(string.lower(p.Name), search) or string.find(string.lower(p.DisplayName), search) then
				targetPlayer = p
				break
			end
		end

		if not targetPlayer or targetPlayer == utils.LocalPlayer or not targetPlayer.Character then return end

		local tRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
		local myChar = utils.LocalPlayer.Character
		local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
		local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")

		if not tRoot or not myRoot or not myHum or myHum.SeatPart then return end

		local oldV = myRoot.AssemblyLinearVelocity
		local oldC = myRoot.CFrame
		local bV = Instance.new("BodyVelocity")
		bV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
		bV.Velocity = Vector3.new(99999, 99999, 99999)
		bV.Parent = myRoot

		local start = os.clock()
		while os.clock() - start < 0.4 do
			utils.RunService.Heartbeat:Wait()
			if tRoot and myRoot and not myHum.SeatPart then
				myRoot.CFrame = tRoot.CFrame + Vector3.new(math.random(-1,1), 0, math.random(-1,1))
			else break end
		end

		bV:Destroy()
		myRoot.AssemblyLinearVelocity = oldV
		myRoot.CFrame = oldC
	end
}

local function isNPCModel(model)
	if not model or not model:IsA("Model") then return false end
	local hum = model:FindFirstChildOfClass("Humanoid")
	return hum ~= nil and not Players:GetPlayerFromCharacter(model)
end

local function trackNPC(model)
	if not isNPCModel(model) then return end
	trackedNPCs[model] = true
end

local function untrackNPC(model)
	if not model then return end
	if trackedNPCs[model] then
		_G.Mechanics.restoreNPC(model)
		_G.GraphicsEngine.removeNPCLabel(model)
		trackedNPCs[model] = nil
	end
end

for _, desc in ipairs(Workspace:GetDescendants()) do
	if desc:IsA("Humanoid") and desc.Parent and isNPCModel(desc.Parent) then
		trackNPC(desc.Parent)
	end
end

Workspace.DescendantAdded:Connect(function(desc)
	if desc:IsA("Humanoid") and desc.Parent and isNPCModel(desc.Parent) then
		trackNPC(desc.Parent)
	end
end)

Workspace.DescendantRemoving:Connect(function(desc)
	if desc:IsA("Humanoid") then
		untrackNPC(desc.Parent)
	end
end)

-- PART 4: Scaling Pipelines and Dynamic Rendering Loops
local utils = _G.CoreUtils
local mech = _G.Mechanics
local originalProps, npcHitboxes = _G.OriginalProps, _G.NpcHitboxes

_G.Pipeline = {
	applyToPlayer = function(player)
		if not player or not player.Character or player == utils.LocalPlayer then return end
		if not mech.shouldApplyHitbox(player) then
			if originalProps[player] then mech.restorePlayer(player) end
			return
		end

		local char = player.Character
		local hum = char:FindFirstChildOfClass("Humanoid")
		local isSitting = (hum and hum.SeatPart and (hum.SeatPart:IsA("VehicleSeat") or hum.SeatPart:IsA("Seat")))
		pcall(function()
			local actualTarget = isSitting and "Head" or _G.TargetPart
			local part = char:FindFirstChild(actualTarget) or char:FindFirstChild("HumanoidRootPart")
			if not part or not part:IsA("BasePart") then return end
			if originalProps[player] and not originalProps[player][part.Name] then mech.restorePlayer(player) end
			mech.storeOriginal(player, part.Name)
			local curSize = (part.Name == "HumanoidRootPart") and _G.RootSize or _G.HeadSize
			if _G.HitboxScaleMode == "Large" then curSize = curSize * 2.5 elseif _G.HitboxScaleMode == "Small" then curSize = curSize * 0.6 end
			utils.safeSetProperty(part, "Size", Vector3.new(curSize, curSize, curSize))
			utils.safeSetProperty(part, "Transparency", _G.HitboxTransparency)
			utils.safeSetProperty(part, "Material", Enum.Material.SmoothPlastic)
			utils.safeSetProperty(part, "CanCollide", false)
			utils.safeSetProperty(part, "CanTouch", true)

			if part.Name == "Head" then 
				if hum and hum.RigType == Enum.HumanoidRigType.R6 then
					utils.safeSetProperty(part, "Massless", false)
				else
					utils.safeSetProperty(part, "Massless", true)
				end
			end
		end)
	end,
	applyToNPC = function(npc)
		if not npc then return end
		pcall(function()
			local part = npc:FindFirstChild("Head")
			if not part or not part:IsA("BasePart") then return end
			mech.storeNPCOriginal(npc, part.Name)
			local tSize = _G.HeadSize 
			if _G.HitboxScaleMode == "Large" then tSize = tSize * 2.5 elseif _G.HitboxScaleMode == "Small" then tSize = tSize * 0.6 end
			utils.safeSetProperty(part, "Size", Vector3.new(tSize, tSize, tSize))
			utils.safeSetProperty(part, "Transparency", _G.HitboxTransparency)
			utils.safeSetProperty(part, "Material", Enum.Material.SmoothPlastic)
			utils.safeSetProperty(part, "CanCollide", false)
			utils.safeSetProperty(part, "CanTouch", true)

			local hum = npc:FindFirstChildOfClass("Humanoid")
			if hum and hum.RigType == Enum.HumanoidRigType.R6 then
				utils.safeSetProperty(part, "Massless", false)
			else
				utils.safeSetProperty(part, "Massless", true)
			end
		end)
	end
}

