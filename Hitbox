-- Anti-Kick Property Proxy Engine
local function safeSetProperty(instance, property, value)
	if not instance or not instance:IsDescendantOf(game) then return end
	pcall(function()
		instance[property] = value
	end)
end

local function hasForceField(character)
	return character and character:FindFirstChildOfClass("ForceField") ~= nil
end

local function getTeamColor(player)
	if player and player.Team then return player.TeamColor.Color end
	return Color3.fromRGB(255, 255, 255)
end

