local function connectPlayerSignals(p)
	local function setupChar(char)
		graphics.removeESPHighlight(p); graphics.removeESPLabel(p)
		local head = char:WaitForChild("Head", 5)
		if head then task.wait(0.05) globalESPUpdate() end
	end
	if p.Character then task.spawn(setupChar, p.Character) end
	p.CharacterAdded:Connect(setupChar)
	p:GetPropertyChangedSignal("Team"):Connect(function() task.wait(0.05); globalESPUpdate() end)
end

for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then connectPlayerSignals(p) end end
