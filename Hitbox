-- Button behaviors
toggleButton.MouseButton1Click:Connect(function()
    _G.Disabled = not _G.Disabled
    if not _G.Disabled then
        -- turning hitbox OFF -> restore everything
        restoreAll()
    else
        -- turning hitbox ON -> apply to all players (will store originals), respecting team check
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and shouldApplyToPlayer(p) then
                applyToPlayer(p)
            end
        end
    end
end)

changeButton.MouseButton1Click:Connect(function()
    -- Switch between HumanoidRootPart and Head
    -- before switching, restore previous changes so we don't leave modified parts behind
    restoreAll()
    if _G.TargetPart == "HumanoidRootPart" then
        _G.TargetPart = "Head"
    else
        _G.TargetPart = "HumanoidRootPart"
    end
    -- If currently enabled, apply to new target immediately
    if _G.Disabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and shouldApplyToPlayer(p) then
                applyToPlayer(p)
            end
        end
    end
end)

increaseButton.MouseButton1Click:Connect(function()
    _G.HeadSize = _G.HeadSize + 5
    updateSizeLabel()
    -- apply immediately if enabled
    if _G.Disabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and shouldApplyToPlayer(p) then
                applyToPlayer(p)
            end
        end
    end
end)

decreaseButton.MouseButton1Click:Connect(function()
    _G.HeadSize = _G.HeadSize - 5
    if _G.HeadSize < 1 then _G.HeadSize = 1 end
    updateSizeLabel()
    -- apply immediately if enabled
    if _G.Disabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and shouldApplyToPlayer(p) then
                applyToPlayer(p)
            end
        end
    end
end)

toggleTeamButton.MouseButton1Click:Connect(function()
    _G.TeamCheck = not _G.TeamCheck
    updateTeamButton()

    -- restore then reapply according to new team check state
    restoreAll()
    if _G.Disabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and shouldApplyToPlayer(p) then
                applyToPlayer(p)
            end
        end
    end
end)

-- Initialize UI labels
updateSizeLabel()
updateTeamButton()
