-- JanBlox Gui Pro Version (LocalScript)
-- Place this script in StarterGui (or PlayerScripts) so it runs for the LocalPlayer

-- Original settings from your script
_G.HeadSize = 5
_G.Disabled = true -- note: your original script applies the hitbox when this is true
_G.TargetPart = "HumanoidRootPart" -- can be "HumanoidRootPart" or "Head"
_G.NPCHitbox = false -- NPC hitbox toggle

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")

-- Store original properties so we can restore them later
local originalProps = {} -- originalProps[player] = { [partName] = {Size, Transparency, BrickColor, Material, CanCollide} }
local npcHitboxes = {} -- Track which NPCs have hitboxes applied

local function storeOriginal(player, partName)
    if not player or not player.Character then return end
    if not originalProps[player] then originalProps[player] = {} end
    if originalProps[player][partName] then return end -- already saved
    local part = player.Character:FindFirstChild(partName)
    if part and part:IsA("BasePart") then
        originalProps[player][partName] = {
            Size = part.Size,
            Transparency = part.Transparency,
            BrickColor = part.BrickColor,
            Material = part.Material,
            CanCollide = part.CanCollide,
        }
    end
end

local function storeNPCOriginal(npc, partName)
    if not npc then return end
    if not npcHitboxes[npc] then npcHitboxes[npc] = {} end
    if npcHitboxes[npc][partName] then return end
    local part = npc:FindFirstChild(partName)
    if part and part:IsA("BasePart") then
        npcHitboxes[npc][partName] = {
            Size = part.Size,
            Transparency = part.Transparency,
            BrickColor = part.BrickColor,
            Material = part.Material,
            CanCollide = part.CanCollide,
        }
    end
end

local function applyToPlayer(player)
    if not player or not player.Character then return end
    if player == LocalPlayer then return end -- keep same exclusion as original
    pcall(function()
        local part = player.Character:FindFirstChild(_G.TargetPart)
        if not part or not part:IsA("BasePart") then
            -- fallback to HumanoidRootPart if requested target missing
            part = player.Character:FindFirstChild("HumanoidRootPart")
            if not part then return end
        end

        storeOriginal(player, part.Name)
        part.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize)
        part.Transparency = 0.7
        part.BrickColor = BrickColor.new("Really blue")
        part.Material = Enum.Material.Neon
        part.CanCollide = false
    end)
end

local function applyToNPC(npc)
    if not npc then return end
    pcall(function()
        -- Try to find HumanoidRootPart or Torso
        local part = npc:FindFirstChild("HumanoidRootPart")
        if not part then
            part = npc:FindFirstChild("Torso")
        end
        if not part then return end

        storeNPCOriginal(npc, part.Name)
        part.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize)
        part.Transparency = 0.7
        part.BrickColor = BrickColor.new("Really blue")
        part.Material = Enum.Material.Neon
        part.CanCollide = false
    end)
end

local function restorePlayer(player)
    if not player then return end
    local data = originalProps[player]
    if not data or not player.Character then
        originalProps[player] = nil
        return
    end

    for partName, props in pairs(data) do
        local part = player.Character:FindFirstChild(partName)
        if part and part:IsA("BasePart") and props then
            -- restore saved properties
            pcall(function()
                part.Size = props.Size
                part.Transparency = props.Transparency
                part.BrickColor = props.BrickColor
                part.Material = props.Material
                part.CanCollide = props.CanCollide
            end)
        end
    end

    originalProps[player] = nil
end

local function restoreNPC(npc)
    if not npc then return end
    local data = npcHitboxes[npc]
    if not data then return end

    for partName, props in pairs(data) do
        local part = npc:FindFirstChild(partName)
        if part and part:IsA("BasePart") and props then
            pcall(function()
                part.Size = props.Size
                part.Transparency = props.Transparency
                part.BrickColor = props.BrickColor
                part.Material = props.Material
                part.CanCollide = props.CanCollide
            end)
        end
    end

    npcHitboxes[npc] = nil
end

local function restorePlayerFully(player)
    if not player or not player.Character then return end
    
    -- Restore both HumanoidRootPart and Head
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    local head = player.Character:FindFirstChild("Head")
    
    if hrp and originalProps[player] and originalProps[player]["HumanoidRootPart"] then
        local props = originalProps[player]["HumanoidRootPart"]
        pcall(function()
            hrp.Size = props.Size
            hrp.Transparency = props.Transparency
            hrp.BrickColor = props.BrickColor
            hrp.Material = props.Material
            hrp.CanCollide = props.CanCollide
        end)
    end
    
    if head and originalProps[player] and originalProps[player]["Head"] then
        local props = originalProps[player]["Head"]
        pcall(function()
            head.Size = props.Size
            head.Transparency = props.Transparency
            head.BrickColor = props.BrickColor
            head.Material = props.Material
            head.CanCollide = props.CanCollide
        end)
    end
    
    originalProps[player] = nil
end

local function restoreAll()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            restorePlayer(player)
        end
    end
end

local function restoreAllNPCs()
    for npc, _ in pairs(npcHitboxes) do
        restoreNPC(npc)
    end
end

-- Reapply or restore on CharacterAdded
Players.PlayerAdded:Connect(function(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function()
        -- Clear old data for this player
        originalProps[player] = nil
        -- small delay to allow parts to exist
        wait(0.1)
        if _G.Disabled then
            applyToPlayer(player)
        end
    end)
end)

-- If the script starts after players are already present, connect their CharacterAdded and maybe apply
for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        player.CharacterAdded:Connect(function()
            -- Clear old data for this player
            originalProps[player] = nil
            wait(0.1)
            if _G.Disabled then applyToPlayer(player) end
        end)
        -- if character already exists, apply immediately if enabled
        if player.Character and _G.Disabled then
            applyToPlayer(player)
        end
    end
end

-- RenderStepped loop preserving original behavior: when _G.Disabled is true we apply the hitbox
-- Also check if players are dead and remove hitbox
RunService.RenderStepped:Connect(function()
    if _G.Disabled then
        -- Apply to players
        for _, v in next, Players:GetPlayers() do
            if v ~= LocalPlayer and v.Character then
                local humanoid = v.Character:FindFirstChild("Humanoid")
                -- If player is dead (Health <= 0), restore their parts FULLY
                if humanoid and humanoid.Health <= 0 then
                    restorePlayerFully(v)
                else
                    -- If player is alive, apply hitbox
                    applyToPlayer(v)
                end
            end
        end

        -- Apply to NPCs if NPC hitbox is enabled
        if _G.NPCHitbox then
            for _, npc in ipairs(Workspace:GetDescendants()) do
                if npc:IsA("Model") and npc ~= LocalPlayer.Character then
                    -- Check if it's an NPC (has Humanoid but not a Player)
                    local humanoid = npc:FindFirstChild("Humanoid")
                    if humanoid and not Players:FindFirstChild(npc.Name) then
                        if humanoid.Health > 0 then
                            applyToNPC(npc)
                        else
                            restoreNPC(npc)
                        end
                    end
                end
            end
        else
            -- If NPC hitbox is off, restore all NPCs
            restoreAllNPCs()
        end
    else
        -- If main hitbox is off, restore everything
        restoreAll()
        restoreAllNPCs()
    end
end)

