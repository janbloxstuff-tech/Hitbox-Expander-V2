					if _G.TeamCheck and p.Team == LocalPlayer.Team then graphics.removeESPLabel(p) else graphics.createESPLabel(p) end
				end
			end
		end
		if _G.NPCESPEnabled then
			for npc, _ in pairs(trackedNPCs) do
				if npc.Parent then if not npcLabels[npc] then graphics.createNPCLabel(npc) end else graphics.removeNPCLabel(npc) end
			end
		end
