-- JanBlox Gui Pro Version (LocalScript)
-- Place this script in StarterGui (or PlayerScripts) so it runs for the LocalPlayer

-- Original settings from your script
_G.HeadSize = 50
_G.Disabled = true -- note: your original script applies the hitbox when this is true
_G.TargetPart = "HumanoidRootPart" -- can be "HumanoidRootPart" or "Head"

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Store original properties so we can restore them later
local originalProps = {} -- originalProps[player] = { [partName] = {Size, Transparency, BrickColor, Material, CanCollide} }

local function storeOriginal(player, partName)
    if not player or not player.Character then return end
    if not originalProps[player] then originalProps[player] = {} end
    if originalProps[player][partName] then return end -- already saved
    local part = player.Character:FindFirstChild(partName)
    if part and part:IsA("BasePart") then
        originalProps[player][partName] = {
            Size = part.Size,
            Transparency = part.Transparency,
            BrickColor = part.BrickColor,
            Material = part.Material,
            CanCollide = part.CanCollide,
        }
    end
end

local function applyToPlayer(player)
    if not player or not player.Character then return end
    if player == LocalPlayer then return end -- keep same exclusion as original
    pcall(function()
        local part = player.Character:FindFirstChild(_G.TargetPart)
        if not part or not part:IsA("BasePart") then
            -- fallback to HumanoidRootPart if requested target missing
            part = player.Character:FindFirstChild("HumanoidRootPart")
            if not part then return end
        end

        storeOriginal(player, part.Name)
        part.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize)
        part.Transparency = 0.7
        part.BrickColor = BrickColor.new("Really blue")
        part.Material = Enum.Material.Neon
        part.CanCollide = false
    end)
end

local function restorePlayer(player)
    if not player then return end
    local data = originalProps[player]
    if not data or not player.Character then
        originalProps[player] = nil
        return
    end

    for partName, props in pairs(data) do
        local part = player.Character:FindFirstChild(partName)
        if part and part:IsA("BasePart") and props then
            -- restore saved properties
            pcall(function()
                part.Size = props.Size
                part.Transparency = props.Transparency
                part.BrickColor = props.BrickColor
                part.Material = props.Material
                part.CanCollide = props.CanCollide
            end)
        end
    end

    originalProps[player] = nil
end

local function restoreAll()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            restorePlayer(player)
        end
    end
end

-- Reapply or restore on CharacterAdded
Players.PlayerAdded:Connect(function(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function()
        -- small delay to allow parts to exist
        wait(0.1)
        if _G.Disabled then
            applyToPlayer(player)
        end
    end)
end)

-- If the script starts after players are already present, connect their CharacterAdded and maybe apply
for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        player.CharacterAdded:Connect(function()
            wait(0.1)
            if _G.Disabled then applyToPlayer(player) end
        end)
        -- if character already exists, apply immediately if enabled
        if player.Character and _G.Disabled then
            applyToPlayer(player)
        end
    end
end

-- RenderStepped loop preserving original behavior: when _G.Disabled is true we apply the hitbox
RunService.RenderStepped:Connect(function()
    if _G.Disabled then
        for _, v in next, Players:GetPlayers() do
            if v ~= LocalPlayer then
                applyToPlayer(v)
            end
        end
    end
end)

-- Create the GUI
local playerGui = LocalPlayer:WaitForChild("PlayerGui")

-- Remove existing GUI with same name to avoid duplicates
local existing = playerGui:FindFirstChild("JanBlox Gui Pro Version")
if existing then existing:Destroy() end

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "JanBlox Gui Pro Version"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 100)
frame.Position = UDim2.new(0, 10, 0, 10)
frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
frame.BorderSizePixel = 0
frame.Parent = screenGui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 24)
title.Position = UDim2.new(0, 0, 0, 0)
title.BackgroundTransparency = 1
title.Text = "JanBlox Gui Pro Version"
title.TextColor3 = Color3.new(1,1,1)
title.Font = Enum.Font.GothamBold
title.TextSize = 14
title.Parent = frame

local toggleButton = Instance.new("TextButton")
toggleButton.Name = "ToggleHitboxButton"
toggleButton.Size = UDim2.new(1, -10, 0, 34)
toggleButton.Position = UDim2.new(0, 5, 0, 30)
toggleButton.BackgroundColor3 = Color3.fromRGB(50,50,50)
toggleButton.TextColor3 = Color3.new(1,1,1)
toggleButton.Font = Enum.Font.Gotham
toggleButton.TextSize = 14
toggleButton.Text = "Toggle Hitbox"
toggleButton.Parent = frame

local changeButton = Instance.new("TextButton")
changeButton.Name = "ChangeHitboxButton"
changeButton.Size = UDim2.new(1, -10, 0, 34)
changeButton.Position = UDim2.new(0, 5, 0, 66)
changeButton.BackgroundColor3 = Color3.fromRGB(50,50,50)
changeButton.TextColor3 = Color3.new(1,1,1)
changeButton.Font = Enum.Font.Gotham
changeButton.TextSize = 14
changeButton.Text = "Change Hitbox"
changeButton.Parent = frame

-- Button behaviors
toggleButton.MouseButton1Click:Connect(function()
    -- Toggle according to your original pattern: when _G.Disabled == true, the hitbox is active.
    _G.Disabled = not _G.Disabled

    if not _G.Disabled then
        -- turning hitbox OFF -> restore everything
        restoreAll()
    else
        -- turning hitbox ON -> apply to all players (will store originals)
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                applyToPlayer(p)
            end
        end
    end
end)

changeButton.MouseButton1Click:Connect(function()
    -- Switch between HumanoidRootPart and Head
    -- before switching, restore previous changes so we don't leave modified parts behind
    restoreAll()
    if _G.TargetPart == "HumanoidRootPart" then
        _G.TargetPart = "Head"
    else
        _G.TargetPart = "HumanoidRootPart"
    end
    -- If currently enabled, apply to new target immediately
    if _G.Disabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                applyToPlayer(p)
            end
        end
    end
end)
