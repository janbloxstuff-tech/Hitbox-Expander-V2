-- PART 4: SIZE SCALE TRANSLATORS & THREAD SAFETY LOOPS
local utils = _G.CoreUtils
local mech = _G.Mechanics
local Logger = utils.Logger
local originalProps, npcHitboxes = _G.OriginalProps, _G.NpcHitboxes

_G.Pipeline = {
	applyToPlayer = function(player)
		if not player or not player.Character or player == utils.LocalPlayer then return end
		
		local currentHum = player.Character:FindFirstChildOfClass("Humanoid")
		if not currentHum or currentHum.Health <= 0 then
			if originalProps[player] then mech.restorePlayer(player) end
			return
		end

		if not mech.shouldApplyHitbox(player) then
			if originalProps[player] then mech.restorePlayer(player) end
			return
		end

		local char = player.Character
		pcall(function()
			local isSitting = (currentHum and currentHum.SeatPart and (currentHum.SeatPart:IsA("VehicleSeat") or currentHum.SeatPart:IsA("Seat")))
			local actualTarget = isSitting and "Head" or _G.TargetPart
			local part = char:FindFirstChild(actualTarget) or char:FindFirstChild("HumanoidRootPart")
			
			if not part or not part:IsA("BasePart") then return end
			if originalProps[player] and not originalProps[player][part.Name] then mech.restorePlayer(player) end
			
			mech.storeOriginal(player, part.Name)
			local curSize = (part.Name == "HumanoidRootPart") and _G.RootSize or _G.HeadSize
			
			if _G.HitboxScaleMode == "Large" then 
				curSize = curSize * 2.5 
			elseif _G.HitboxScaleMode == "Small" then 
				curSize = curSize * 0.6 
			end
			
			utils.safeSetProperty(part, "Size", Vector3.new(curSize, curSize, curSize))
			utils.safeSetProperty(part, "Transparency", _G.HitboxTransparency)
			utils.safeSetProperty(part, "Material", Enum.Material.SmoothPlastic)
			utils.safeSetProperty(part, "CanCollide", false)
			utils.safeSetProperty(part, "CanTouch", true)

			if part.Name == "Head" then 
				if currentHum and currentHum.RigType == Enum.HumanoidRigType.R6 then
					utils.safeSetProperty(part, "Massless", true)
				else
					utils.safeSetProperty(part, "Massless", false)
				end
			end
		end)
	end,
	
	applyToNPC = function(npc)
		if not npc then return end
		local currentHum = npc:FindFirstChildOfClass("Humanoid")
		if not currentHum or currentHum.Health <= 0 then return end
		
		pcall(function()
			local part = npc:FindFirstChild("Head")
			if not part or not part:IsA("BasePart") then return end
			mech.storeNPCOriginal(npc, part.Name)
			
			local tSize = _G.HeadSize 
			if _G.HitboxScaleMode == "Large" then 
				tSize = tSize * 2.5 
			elseif _G.HitboxScaleMode == "Small" then 
				tSize = tSize * 0.6 
			end
			
			utils.safeSetProperty(part, "Size", Vector3.new(tSize, tSize, tSize))
			utils.safeSetProperty(part, "Transparency", _G.HitboxTransparency)
			utils.safeSetProperty(part, "Material", Enum.Material.SmoothPlastic)
			utils.safeSetProperty(part, "CanCollide", false)
			utils.safeSetProperty(part, "CanTouch", true)

			if currentHum and currentHum.RigType == Enum.HumanoidRigType.R6 then
				utils.safeSetProperty(part, "Massless", true)
			else
				utils.safeSetProperty(part, "Massless", false)
			end
		end)
	end
}

-- Active Structural Processing Engine
utils.RunService.Heartbeat:Connect(function()
	local myChar = utils.LocalPlayer.Character
	if myChar then
		local myHum = myChar:FindFirstChildOfClass("Humanoid")
		local myRoot = myChar:FindFirstChild("HumanoidRootPart")
		
		if myHum and myRoot then
			-- Constraint Engine
			if _G.PlayerModEnabled then
				if _G.WalkSpeedToggle then
					myHum.WalkSpeed = math.clamp(_G.CustomWalkSpeed, 0, 500)
				end
				if _G.JumpPowerToggle then
					myHum.UseJumpPower = true
					myHum.JumpPower = math.clamp(_G.CustomJumpPower, 0, 500)
				end
			end
			
			-- Physical Layout Mod Shifters
			if _G.LayModEnabled then
				if myHum.RigType == Enum.HumanoidRigType.R15 then
					local lowerTorso = myChar:FindFirstChild("LowerTorso")
					local rootJoint = lowerTorso and lowerTorso:FindFirstChild("RootJoint")
					if rootJoint then
						rootJoint.C0 = CFrame.new(0, -2.2, 0) * CFrame.Angles(math.rad(-90), 0, 0)
					end
				else
					myHum.HipHeight = -1.5
				end
			else
				if myHum.RigType == Enum.HumanoidRigType.R15 then
					local lowerTorso = myChar:FindFirstChild("LowerTorso")
					local rootJoint = lowerTorso and lowerTorso:FindFirstChild("RootJoint")
					if rootJoint then
						rootJoint.C0 = CFrame.new(0, 0, 0) * CFrame.Angles(math.rad(-90), 0, 0)
					end
				end
			end

			-- Underground Displacement Layer
			if _G.UndergroundEnabled then
				for _, part in ipairs(myChar:GetChildren()) do
					if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
						part.CanCollide = false
					end
				end
				local lowerTorso = myChar:FindFirstChild("LowerTorso") or myChar:FindFirstChild("Torso")
				if lowerTorso then
					lowerTorso.AssemblyLinearVelocity = Vector3.new(lowerTorso.AssemblyLinearVelocity.X, 0, lowerTorso.AssemblyLinearVelocity.Z)
				end
				if myHum.RigType == Enum.HumanoidRigType.R15 then
					local lowerTorsoObj = myChar:FindFirstChild("LowerTorso")
					local rootJoint = lowerTorsoObj and lowerTorsoObj:FindFirstChild("RootJoint")
					if rootJoint then rootJoint.C1 = CFrame.new(0, -4.5, 0) end
				elseif myHum.RigType == Enum.HumanoidRigType.R6 then
					local rootJoint = myRoot:FindFirstChild("RootJoint")
					if rootJoint then rootJoint.C1 = CFrame.new(0, 0, 4.5) end
				end
			else
				if myHum.RigType == Enum.HumanoidRigType.R15 then
					local lowerTorsoObj = myChar:FindFirstChild("LowerTorso")
