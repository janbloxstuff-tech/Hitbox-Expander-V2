-- Loop Engine Run ticks
RunService.RenderStepped:Connect(function()
    -- Maintain local stats continuously, persisting past player deaths
    if _G.PlayerModEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        local myHumanoid = LocalPlayer.Character.Humanoid
        if myHumanoid.WalkSpeed ~= _G.CustomWalkSpeed then
            myHumanoid.WalkSpeed = _G.CustomWalkSpeed
        end
        if myHumanoid.JumpPower ~= _G.CustomJumpPower then
            myHumanoid.JumpPower = _G.CustomJumpPower
        end
    end

    for player, labelData in pairs(playerLabels) do
        if player then updateESPLabel(player) end
    end
    
    if _G.Disabled then
        for _, v in next, Players:GetPlayers() do
            if v ~= LocalPlayer and v.Character then
                local humanoid = v.Character:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health <= 0 then
                    restorePlayerFully(v)
                    removeESPHighlight(v)
                else
                    applyToPlayer(v)
                    -- Re-enforce missing highlights dynamically on active targets
                    if _G.ESPEnabled and shouldShowESP(v) and not v.Character:FindFirstChildOfClass("Highlight") then
                        refreshESPForPlayer(v)
                    end
                end
            end
        end

        npcScanCooldown = npcScanCooldown + (1/60)
        if npcScanCooldown >= NPC_SCAN_INTERVAL and _G.NPCHitbox then
            npcScanCooldown = 0
            pcall(function()
                for _, npc in ipairs(Workspace:GetChildren()) do
                    if npc:IsA("Model") and npc ~= LocalPlayer.Character and npc.Parent == Workspace then
                        local humanoid = npc:FindFirstChild("Humanoid")
                        local isPlayer = Players:FindFirstChild(npc.Name)
                        if humanoid and not isPlayer then
                            if not trackedNPCs[npc] then trackedNPCs[npc] = true end
                            if humanoid.Health > 0 then applyToNPC(npc) else restoreNPC(npc) end
                        end
                    end
                end
            end)
        end
    else
        restoreAll()
        restoreAllNPCs()
    end
end) 
