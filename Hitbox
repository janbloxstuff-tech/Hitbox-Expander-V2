-- GLOBAL TASK RUNNERS (Your Hitbox/Walkspeed/Jumppower loops run completely intact here!)
local function globalESPUpdate()
	if not _G.ESPEnabled then return end
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character then
			if _G.Mechanics.shouldApplyHitbox(p) then graphics.createESPHighlight(p) graphics.createESPLabel(p)
			else graphics.removeESPHighlight(p) graphics.removeESPLabel(p) end
		end
	end
end

RunService.Heartbeat:Connect(function()
	if not _G.Disabled then
		for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then _G.Pipeline.applyToPlayer(p) end end
	end

	if _G.NPCHitbox then
		for npc, _ in pairs(trackedNPCs) do
			if npc and npc.Parent then
				local hum = npc:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 then
					_G.Pipeline.applyToNPC(npc)
					if _G.NPCESPEnabled then if not npcLabels[npc] then graphics.createNPCLabel(npc) end else graphics.removeNPCLabel(npc) end
				else mech.restoreNPC(npc) graphics.removeNPCLabel(npc) end
			else untrackNPC(npc) end
		end
	else
		mech.restoreAllNPCs()
		for npc, _ in pairs(npcLabels) do graphics.removeNPCLabel(npc) end
		for npc, _ in pairs(trackedNPCs) do untrackNPC(npc) end
	end

	-- core modifications loop
	if LocalPlayer.Character then
		local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
		if hum then
			if _G.PlayerModEnabled then
				if _G.WalkSpeedToggle then hum.WalkSpeed = _G.CustomWalkSpeed end
				if _G.JumpPowerToggle then hum.UseJumpPower = true hum.JumpPower = _G.CustomJumpPower end
			end
		end
	end

	if _G.LoopFullBright then Lighting.Ambient = Color3.fromRGB(255, 255, 255) Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255) Lighting.ClockTime = 14 end
end)

Players.PlayerAdded:Connect(function(p)
	p.CharacterAdded:Connect(function(char)
		task.spawn(function() char:WaitForChild("HumanoidRootPart", 3) globalESPUpdate() end)
	end)
	p:GetPropertyChangedSignal("Team"):Connect(function() task.wait(0.1) globalESPUpdate() updateTeleportMenu() updateJumpscareMenu() end)
	updateTeleportMenu() updateJumpscareMenu()
end)

