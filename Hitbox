-- Place this script in StarterGui or PlayerScripts

-- Settings
_G.HeadSize = 5
_G.HitboxTransparency = 0.5
_G.Disabled = true -- Set to true by default to run on start
_G.TargetPart = "HumanoidRootPart"
_G.NPCHitbox = false
_G.ESPEnabled = false
_G.ShowName = true
_G.ShowHealth = true
_G.TeamCheck = false

-- Player Config Settings
_G.CustomWalkSpeed = 16
_G.CustomJumpPower = 50
_G.PlayerModEnabled = false

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")

-- Store original properties
local originalProps = {}
local npcHitboxes = {}
local espHighlights = {}
local playerLabels = {}
local trackedNPCs = {}

local npcScanCooldown = 0
local NPC_SCAN_INTERVAL = 1

local function storeOriginal(player, partName)
    if not player or not player.Character then return end
    if not originalProps[player] then originalProps[player] = {} end
    if originalProps[player][partName] then return end
    local part = player.Character:FindFirstChild(partName)
    if part and part:IsA("BasePart") then
        originalProps[player][partName] = {
            Size = part.Size,
            Transparency = part.Transparency,
            BrickColor = part.BrickColor,
            Material = part.Material,
            CanCollide = part.CanCollide,
        }
    end
end

local function storeNPCOriginal(npc, partName)
    if not npc then return end
    if not npcHitboxes[npc] then npcHitboxes[npc] = {} end
    if npcHitboxes[npc][partName] then return end
    local part = npc:FindFirstChild(partName)
    if part and part:IsA("BasePart") then
        npcHitboxes[npc][partName] = {
            Size = part.Size,
            Transparency = part.Transparency,
            BrickColor = part.BrickColor,
            Material = part.Material,
            CanCollide = part.CanCollide,
        }
    end
end

local function shouldApplyHitbox(player)
    if not _G.TeamCheck then return true end
    if not LocalPlayer or not LocalPlayer.Character then return false end
    return player.Team ~= LocalPlayer.Team
end

local function applyToPlayer(player)
    if not player or not player.Character then return end
    if player == LocalPlayer then return end
    if not shouldApplyHitbox(player) then return end
    
    pcall(function()
        local part = player.Character:FindFirstChild(_G.TargetPart)
        if not part or not part:IsA("BasePart") then
            part = player.Character:FindFirstChild("HumanoidRootPart")
            if not part then return end
        end

        storeOriginal(player, part.Name)
        part.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize)
        part.Transparency = _G.HitboxTransparency
        part.Material = Enum.Material.SmoothPlastic
        part.CanCollide = false
    end)
end

local function applyToNPC(npc)
    if not npc then return end
    pcall(function()
        local part = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Torso")
        if not part then return end

        storeNPCOriginal(npc, part.Name)
        part.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize)
        part.Transparency = _G.HitboxTransparency
        part.Material = Enum.Material.SmoothPlastic
        part.CanCollide = false
    end)
end

local function restorePlayer(player)
    if not player then return end
    local data = originalProps[player]
    if not data or not player.Character then
        originalProps[player] = nil
        return
    end

    for partName, props in pairs(data) do
        local part = player.Character:FindFirstChild(partName)
        if part and part:IsA("BasePart") and props then
            pcall(function()
                part.Size = props.Size
                part.Transparency = props.Transparency
                part.BrickColor = props.BrickColor
                part.Material = props.Material
                part.CanCollide = props.CanCollide
            end)
        end
    end
    originalProps[player] = nil
end

local function restoreNPC(npc)
    if not npc then return end
    local data = npcHitboxes[npc]
    if not data then return end

    for partName, props in pairs(data) do
        local part = npc:FindFirstChild(partName)
        if part and part:IsA("BasePart") and props then
            pcall(function()
                part.Size = props.Size
                part.Transparency = props.Transparency
                part.BrickColor = props.BrickColor
                part.Material = props.Material
                part.CanCollide = props.CanCollide
            end)
        end
    end
    npcHitboxes[npc] = nil
end

local function restorePlayerFully(player)
    if not player or not player.Character then return end
    restorePlayer(player)
end

local function restoreAll()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then restorePlayer(player) end
    end
end

local function restoreAllNPCs()
    for npc, _ in pairs(npcHitboxes) do restoreNPC(npc) end
    trackedNPCs = {}
end

local function removeESPHighlight(player)
    if espHighlights[player] then
        pcall(function() espHighlights[player]:Destroy() end)
        espHighlights[player] = nil
    end
end

local function removeESPLabel(player)
    if playerLabels[player] then
        pcall(function() playerLabels[player].gui:Destroy() end)
        playerLabels[player] = nil
    end
end

local function createESPHighlight(player)
    if not player.Character then return end
    
    -- Force clear any existing highlights (including game team highlights or older buggy instances)
    for _, child in ipairs(player.Character:GetChildren()) do
        if child:IsA("Highlight") then
            pcall(function() child:Destroy() end)
        end
    end
    
    pcall(function()
        local highlight = Instance.new("Highlight")
        highlight.Adornee = player.Character
        highlight.FillColor = Color3.fromRGB(255, 0, 0)
        highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
        highlight.Parent = player.Character
        espHighlights[player] = highlight
    end)
end

local function createESPLabel(player)
    if playerLabels[player] then removeESPLabel(player) end 
    if not player.Character then return end
    
    local targetPart = player.Character:FindFirstChild("Head") or player.Character:FindFirstChild("HumanoidRootPart")
    if not targetPart then return end

    pcall(function()
        local billboardGui = Instance.new("BillboardGui")
        billboardGui.Size = UDim2.new(4, 0, 1.5, 0)
        billboardGui.AlwaysOnTop = true
        billboardGui.MaxDistance = math.huge
        billboardGui.Name = "ESPLabel_" .. player.Name
        billboardGui.Parent = targetPart
        
        local textLabel = Instance.new("TextLabel")
        textLabel.BackgroundTransparency = 1
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.Font = Enum.Font.GothamBold
        textLabel.TextSize = 13
        textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        textLabel.TextStrokeTransparency = 0
        textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        textLabel.Parent = billboardGui
        
        playerLabels[player] = {gui = billboardGui, label = textLabel}
    end)
end

local function updateESPLabel(player)
    if not playerLabels[player] or not player.Character then return end
    local humanoid = player.Character:FindFirstChild("Humanoid")
    
    local healthText = "DEAD"
    local isDead = true
    
    if humanoid then
        if humanoid.Health > 0 then
            healthText = tostring(math.floor(humanoid.Health))
            isDead = false
        end
    end
    
    local displayText = ""
    if _G.ShowName then
        displayText = player.Name
    end
    if _G.ShowHealth then
        if displayText ~= "" then
            displayText = displayText .. " [" .. healthText .. "]"
        else
            displayText = "[" .. healthText .. "]"
        end
    end
    
    playerLabels[player].label.Text = displayText
    playerLabels[player].label.TextColor3 = isDead and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(255, 255, 255)
end

local function shouldShowESP(player)
    if player == LocalPlayer then return false end
    if not _G.ESPEnabled then return false end
    if not _G.TeamCheck then return true end
    return player.Team ~= LocalPlayer.Team
end

local function refreshESPForPlayer(player)
    if shouldShowESP(player) then
        createESPLabel(player)
        createESPHighlight(player)
    else
        removeESPHighlight(player)
        removeESPLabel(player)
    end
end

local function setupCharacterConnections(player)
    player.CharacterAdded:Connect(function(char)
        originalProps[player] = nil
        removeESPLabel(player)
        removeESPHighlight(player)
        
        char:WaitForChild("HumanoidRootPart", 5)
        char:WaitForChild("Humanoid", 5)
        task.wait(0.5) -- Extended engine buffer to cleanly clear competing assets
        
        if _G.Disabled then applyToPlayer(player) end
        refreshESPForPlayer(player)
    end)
end

-- Fixes team swaps dropping highlight structures completely
local function listenToTeamChanges(player)
    player:GetPropertyChangedSignal("Team"):Connect(function()
        task.wait(0.2)
        refreshESPForPlayer(player)
    end)
end

Players.PlayerAdded:Connect(function(player)
    setupCharacterConnections(player)
    listenToTeamChanges(player)
end)

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        setupCharacterConnections(player)
        listenToTeamChanges(player)
        if player.Character then
            refreshESPForPlayer(player)
        end
    end
end
