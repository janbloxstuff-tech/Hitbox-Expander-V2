local function applyXRay()
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and not obj:IsDescendantOf(LocalPlayer.Character) and not game.Players:GetPlayerFromCharacter(obj.Parent) then
			if not xrayCache[obj] then xrayCache[obj] = obj.Transparency end
			obj.Transparency = 0.5
		end
	end
end

local function removeXRay()
	for obj, originalTransparency in pairs(xrayCache) do
		if obj and obj.Parent then pcall(function() obj.Transparency = originalTransparency end) end
	end
	table.clear(xrayCache)
end

