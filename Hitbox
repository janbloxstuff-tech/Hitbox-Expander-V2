-- JanBlox Gui Pro Version (LocalScript)
-- Place this script in StarterGui (or PlayerGui) so it runs for the LocalPlayer

-- Default settings per request
_G.HeadSize = 5               -- default hitbox size
_G.Disabled = true            -- when true the hitbox is active (matches your original pattern)
_G.TargetPart = "HumanoidRootPart" -- "HumanoidRootPart" or "Head"
_G.TeamCheck = false          -- when true, only apply hitboxes to players NOT on your team (if teams exist)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TeamsService = game:GetService("Teams")
local LocalPlayer = Players.LocalPlayer

-- Store original properties so we can restore them later
-- originalProps[player] = { [partName] = { Size, Transparency, BrickColor, Material, CanCollide, CanQuery, MeshClones = {clone,...} } }
local originalProps = {}

local function safeWait(t)
    if typeof(t) == "number" and t > 0 then
        wait(t)
    end
end

local function storeOriginal(player, partName)
    if not player or not player.Character then return end
    originalProps[player] = originalProps[player] or {}
    if originalProps[player][partName] then return end -- already saved for this character/part

    local part = player.Character:FindFirstChild(partName)
    if not part or not part:IsA("BasePart") then return end

    local data = {
        Size = part.Size,
        Transparency = part.Transparency,
        BrickColor = part.BrickColor,
        Material = part.Material,
        CanCollide = part.CanCollide,
        CanQuery = part:FindFirstChildWhichIsA and part.CanQuery or nil,
        MeshClones = {},
    }

    -- Save and remove mesh children (SpecialMesh, Mesh, BlockMesh)
    for _, child in ipairs(part:GetChildren()) do
        if child:IsA("SpecialMesh") or child:IsA("Mesh") or child:IsA("BlockMesh") then
            -- clone so we can re-add later, then destroy original
            local ok, clone = pcall(function() return child:Clone() end)
            if ok and clone then
                table.insert(data.MeshClones, clone)
            end
            pcall(function() child:Destroy() end)
        end
    end

    originalProps[player][partName] = data
end

local function restorePlayer(player)
    if not player then return end
    local pdata = originalProps[player]
    if not pdata or not player.Character then
        originalProps[player] = nil
        return
    end

    for partName, props in pairs(pdata) do
        local part = player.Character:FindFirstChild(partName)
        if part and part:IsA("BasePart") and props then
            pcall(function()
                if props.Size then part.Size = props.Size end
                if props.Transparency ~= nil then part.Transparency = props.Transparency end
                if props.BrickColor then part.BrickColor = props.BrickColor end
                if props.Material then part.Material = props.Material end
                if props.CanCollide ~= nil then part.CanCollide = props.CanCollide end
                if props.CanQuery ~= nil and part.GetPropertyChangedSignal then
                    -- restore CanQuery if supported
                    pcall(function() part.CanQuery = props.CanQuery end)
                end

                -- reparent saved mesh clones (if any)
                if props.MeshClones and #props.MeshClones > 0 then
                    for _, clone in ipairs(props.MeshClones) do
                        if clone and clone.Parent == nil then
                            pcall(function() clone.Parent = part end)
                        end
                    end
                end
            end)
        end
    end

    originalProps[player] = nil
end

local function shouldApplyToPlayer(player)
    if not player or player == LocalPlayer then return false end
    if not player.Character then return false end
    if not _G.Disabled then return false end

    -- Team check logic
    if _G.TeamCheck then
        -- only apply if teams exist and local player has a team; otherwise if no teams, fallback to applying to everyone
        local hasTeams = #TeamsService:GetTeams() > 0
        if hasTeams and LocalPlayer.Team then
            -- apply only to players on a different team than local player
            if player.Team and player.Team == LocalPlayer.Team then
                return false
            end
        end
    end

    -- Exclude when target part not present
    local target = _G.TargetPart or "HumanoidRootPart"
    local part = player.Character:FindFirstChild(target) or player.Character:FindFirstChild("HumanoidRootPart")
    if not part or not part:IsA("BasePart") then return false end

    -- Exclude dead humanoids
    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
    if humanoid and humanoid.Health <= 0 then return false end

    return true
end

local function applyToPlayer(player)
    if not shouldApplyToPlayer(player) then return end
    pcall(function()
        local targetName = _G.TargetPart or "HumanoidRootPart"
        local part = player.Character:FindFirstChild(targetName)
        if not part or not part:IsA("BasePart") then
            part = player.Character:FindFirstChild("HumanoidRootPart")
            if not part then return end
            targetName = part.Name
        end

        storeOriginal(player, part.Name)

        -- Remove any meshes on the part (storeOriginal already removed them when first called)
        for _, child in ipairs(part:GetChildren()) do
            if child:IsA("SpecialMesh") or child:IsA("Mesh") or child:IsA("BlockMesh") then
                pcall(function() child:Destroy() end)
            end
        end

        -- Apply requested properties (matching your original values + CanQuery false)
        part.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize)
        part.Transparency = 0.7
        part.BrickColor = BrickColor.new("Really blue")
        part.Material = Enum.Material.Neon
        part.CanCollide = false
        pcall(function() part.CanQuery = false end)
    end)
end

local function restoreAll()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            restorePlayer(player)
        end
    end
end

-- Character lifecycle handling: avoid applying to dead players, re-apply on respawn
local function onCharacterAdded(player, character)
    -- small delay for parts to exist
    safeWait(0.1)

    -- When character spawns, if hitbox enabled, apply to them (subject to team check)
    if shouldApplyToPlayer(player) then
        applyToPlayer(player)
    end

    -- Connect death to restore
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.Died:Connect(function()
            -- restore and clear stored props on death
            restorePlayer(player)
        end)
    end

    -- When the character is removed (e.g., respawn), restore any lingering modifications
    player.CharacterRemoving:Connect(function()
        restorePlayer(player)
    end)
end

-- Player added/initialization
Players.PlayerAdded:Connect(function(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function(char) onCharacterAdded(player, char) end)
end)

-- If the script starts after players are already present, attach handlers and maybe apply
for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        player.CharacterAdded:Connect(function(char) onCharacterAdded(player, char) end)
        if player.Character then
            -- apply immediately if enabled
            safeWait(0.05)
            if shouldApplyToPlayer(player) then
                applyToPlayer(player)
            end
        end
    end
end

-- Clean up on player leaving
Players.PlayerRemoving:Connect(function(player)
    originalProps[player] = nil
end)

-- RenderStepped loop: keep applying while enabled (handles players who join / are created after apply)
RunService.RenderStepped:Connect(function()
    if not _G.Disabled then return end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and shouldApplyToPlayer(player) then
            applyToPlayer(player)
        end
    end
end)

