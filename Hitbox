-- Kinetic Force Fling Engine Blueprint
_G.FlingEngine = {
    fling = function(targetName)
        if targetName == "" then return end
        local targetPlayer = nil
        for _, p in ipairs(Players:GetPlayers()) do
            if string.lower(p.Name) == string.lower(targetName) or string.lower(p.DisplayName) == string.lower(targetName) then
                targetPlayer = p; break
            end
        end
        if not targetPlayer or targetPlayer == LocalPlayer or not targetPlayer.Character then return end
        local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local myCharacter = LocalPlayer.Character
        local myRoot = myCharacter and myCharacter:FindFirstChild("HumanoidRootPart")
        local myHumanoid = myCharacter and myCharacter:FindFirstChildOfClass("Humanoid")
        
        if not targetRoot or not myRoot or not myHumanoid or myHumanoid.SeatPart then return end
        
        local originalVelocity = myRoot.AssemblyLinearVelocity
        local originalCFrame = myRoot.CFrame
        local bV = Instance.new("BodyVelocity")
        bV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bV.Velocity = Vector3.new(99999, 99999, 99999)
        bV.Parent = myRoot
        
        local startTime = os.clock()
        while os.clock() - startTime < 0.4 do
            RunService.Heartbeat:Wait()
            if targetRoot and myRoot and not myHumanoid.SeatPart then
                myRoot.CFrame = targetRoot.CFrame + Vector3.new(math.random(-1,1), 0, math.random(-1,1))
            else break end
        end
        bV:Destroy()
        myRoot.AssemblyLinearVelocity = originalVelocity
        myRoot.CFrame = originalCFrame
    end
}

-- Dynamic Scaling Pipeline and Multi-Threading Simulation Hook

local utils = _G.CoreUtils
local mech = _G.Mechanics
local graphics = _G.GraphicsEngine
local originalProps, npcHitboxes, trackedNPCs = _G.OriginalProps, _G.NpcHitboxes, _G.TrackedNPCs

_G.Pipeline = {
    applyToPlayer = function(player)
        if not player or not player.Character or player == LocalPlayer then return end
        if not mech.shouldApplyHitbox(player) then 
            if originalProps[player] then mech.restorePlayer(player) end
            return 
        end
        
        local char = player.Character
        local hum = char:FindFirstChildOfClass("Humanoid")
        local isSitting = (hum and hum.SeatPart and (hum.SeatPart:IsA("VehicleSeat") or hum.SeatPart:IsA("Seat")))

        pcall(function()
            local actualTarget = isSitting and "Head" or _G.TargetPart
            local part = char:FindFirstChild(actualTarget) or char:FindFirstChild("HumanoidRootPart")
            if not part or not part:IsA("BasePart") then return end
            if originalProps[player] and not originalProps[player][part.Name] then mech.restorePlayer(player) end
            
            utils.storeOriginal(player, part.Name)
            local currentSize = (part.Name == "HumanoidRootPart") and _G.RootSize or _G.HeadSize
            if _G.HitboxScaleMode == "Large" then currentSize = currentSize * 2.5 elseif _G.HitboxScaleMode == "Small" then currentSize = currentSize * 0.6 end

            utils.safeSetProperty(part, "Size", Vector3.new(currentSize, currentSize, currentSize))
            utils.safeSetProperty(part, "Transparency", _G.HitboxTransparency)
            utils.safeSetProperty(part, "Material", Enum.Material.SmoothPlastic)
            utils.safeSetProperty(part, "CanCollide", false)
            utils.safeSetProperty(part, "CanTouch", true)
            
            if part.Name == "Head" then utils.safeSetProperty(part, "Massless", true) end
        end)
    end,

    applyToNPC = function(npc)
        if not npc then return end
        if _G.CheckForcefield and utils.hasForceField(npc) then
            if npcHitboxes[npc] then mech.restoreNPC(npc) end
            return
        end

        pcall(function()
            local part = npc:FindFirstChild("Head")
            if not part or not part:IsA("BasePart") then return end
            utils.storeNPCOriginal(npc, part.Name)
            
            local targetSize = 5
            if _G.HitboxScaleMode == "Large" then targetSize = 12.5 elseif _G.HitboxScaleMode == "Small" then targetSize = 3 end

            utils.safeSetProperty(part, "Size", Vector3.new(targetSize, targetSize, targetSize))
            utils.safeSetProperty(part, "Transparency", _G.HitboxTransparency)
            utils.safeSetProperty(part, "Material", Enum.Material.SmoothPlastic)
            utils.safeSetProperty(part, "CanCollide", false)
            utils.safeSetProperty(part, "CanTouch", true)
            utils.safeSetProperty(part, "Massless", true)
        end)
    end
}

