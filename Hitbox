		local char = p.Character
		local head = char:FindFirstChild("Head")
		if not head then return end

		local bbg = Instance.new("BillboardGui")
		bbg.Name = "JanLabel_" .. p.Name
		bbg.Size = UDim2.new(0, 200, 0, 50)
		bbg.AlwaysOnTop = true
		bbg.ExtentsOffset = Vector3.new(0, 3, 0)
		bbg.Adornee = head
		bbg.Parent = ScreenGui

		local list = Instance.new("UIListLayout")
		list.SortOrder = Enum.SortOrder.LayoutOrder
		list.HorizontalAlignment = Enum.HorizontalAlignment.Center
		list.Parent = bbg

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(1, 0, 0, 18)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Text = p.Name
		nameLabel.TextColor3 = (_G.TeamCheck and p.Team == LocalPlayer.Team) and Color3.fromRGB(46, 196, 182) or Color3.fromRGB(255, 255, 255)
		nameLabel.Font = Enum.Font.GothamBold
		nameLabel.TextSize = 12
		nameLabel.TextStrokeTransparency = 0.3
		nameLabel.Visible = _G.ShowName
		nameLabel.Parent = bbg

		local hpLabel = Instance.new("TextLabel")
		hpLabel.Size = UDim2.new(1, 0, 0, 14)
		hpLabel.BackgroundTransparency = 1
		local hum = char:FindFirstChildOfClass("Humanoid")
		hpLabel.Text = hum and "HP: " .. math.floor(hum.Health) or "HP: 100"
		hpLabel.TextColor3 = Color3.fromRGB(43, 147, 72)
		hpLabel.Font = Enum.Font.GothamBold
		hpLabel.TextSize = 11
		hpLabel.TextStrokeTransparency = 0.3
		hpLabel.Visible = _G.ShowHealth
		hpLabel.Parent = bbg

		espLabels[p] = {Gui = bbg, NameLabel = nameLabel, HPLabel = hpLabel}
	end,

	removeESPLabel = function(p)
		if espLabels[p] then
			espLabels[p].Gui:Destroy()
			espLabels[p] = nil
		end
	end,

	createNPCLabel = function(npc)
		if espLabels[npc] or not npc:FindFirstChild("Head") then return end
		local bbg = Instance.new("BillboardGui")
		bbg.Name = "JanNPCLabel_" .. npc.Name
		bbg.Size = UDim2.new(0, 200, 0, 50)
		bbg.AlwaysOnTop = true
		bbg.ExtentsOffset = Vector3.new(0, 3, 0)
		bbg.Adornee = npc.Head
		bbg.Parent = ScreenGui

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(1, 0, 0, 18)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Text = "[NPC] " .. npc.Name
		nameLabel.TextColor3 = Color3.fromRGB(244, 162, 97)
		nameLabel.Font = Enum.Font.GothamBold
		nameLabel.TextSize = 12
		nameLabel.TextStrokeTransparency = 0.3
		nameLabel.Parent = bbg

		npcLabels[npc] = bbg
	end,

	removeNPCLabel = function(npc)
		if npcLabels[npc] then
			npcLabels[npc]:Destroy()
			npcLabels[npc] = nil
		end
	end
}

globalESPUpdate = function()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			if _G.ESPEnabled and p.Character and p.Character:FindFirstChild("Head") then
				local hum = p.Character:FindFirstChildOfClass("Humanoid")
				-- Do not display or process ESP if the character is dead
				if hum and hum.Health <= 0 then
					graphics.removeESPHighlight(p)
					graphics.removeESPLabel(p)
				else
					if _G.TeamCheck and p.Team == LocalPlayer.Team then
						graphics.removeESPHighlight(p)
						graphics.removeESPLabel(p)
					else
						graphics.createESPHighlight(p)
						graphics.createESPLabel(p)
						if espLabels[p] then
							espLabels[p].NameLabel.Visible = _G.ShowName
							espLabels[p].HPLabel.Visible = _G.ShowHealth
							if hum then
								espLabels[p].HPLabel.Text = "HP: " .. math.floor(hum.Health)
							end
						end
					end
				end
			else
				graphics.removeESPHighlight(p)
				graphics.removeESPLabel(p)
			end
		end
	end
end

-- Track Character Health Connections dynamically to resolve the hitbox death-flicker bug
local function trackCharacterLifecycle(p)
	p.CharacterAdded:Connect(function(char)
		local hum = char:WaitForChild("Humanoid", 5)
		if hum then
			hum.HealthChanged:Connect(function(hp)
				if hp <= 0 then
					cleanupHitboxInstantly(p, char)
					graphics.removeESPHighlight(p)
					graphics.removeESPLabel(p)
				end
			end)
		end
	end)
end
for _, p in ipairs(Players:GetPlayers()) do trackCharacterLifecycle(p) end
Players.PlayerAdded:Connect(trackCharacterLifecycle)

local function trackNPC(npc)
	if trackedNPCs[npc] then return end
	trackedNPCs[npc] = true
	local hum = npc:FindFirstChildOfClass("Humanoid")
	if hum then
		hum.HealthChanged:Connect(function(hp)
			if hp <= 0 then
				pipeline.restoreNPC(npc)
				graphics.removeNPCLabel(npc)
			end
		end)
	end
end

local function untrackNPC(npc)
	trackedNPCs[npc] = nil
end

