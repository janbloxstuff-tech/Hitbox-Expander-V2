local function refreshTeamDropdown()
    for _, c in ipairs(teamDropFrame:GetChildren()) do
        if c:IsA("TextButton") or c:IsA("TextLabel") then c:Destroy() end
    end
    
    local allTeams = Teams:GetTeams()
    if #allTeams == 0 then
        local noTeamLabel = Instance.new("TextLabel")
        noTeamLabel.Size = UDim2.new(1, 0, 0, 30)
        noTeamLabel.BackgroundTransparency = 1
        noTeamLabel.Text = "There's no Team in the Game"
        noTeamLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        noTeamLabel.Font = Enum.Font.GothamItalic
        noTeamLabel.TextSize = 12
        noTeamLabel.Parent = teamDropFrame
        teamDropFrame.Size = UDim2.new(1, 0, 0, 35)
    else
        local totalHeight = 0
        for idx, team in ipairs(allTeams) do
            local teamName = team.Name
            local isOff = _G.DisabledTeams[teamName] or false
            local tBtn = createButton("Team ["..teamName.."]: "..(isOff and "OFF" or "ON"), idx, teamDropFrame)
            tBtn.BackgroundColor3 = team.TeamColor.Color
            tBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            
            tBtn.MouseButton1Click:Connect(function()
                _G.DisabledTeams[teamName] = not _G.DisabledTeams[teamName]
                tBtn.Text = "Team ["..teamName.."]: "..(_G.DisabledTeams[teamName] and "OFF" or "ON")
                if not _G.Disabled then mech.restoreAll() end
            end)
            totalHeight = totalHeight + 38
        end
        teamDropFrame.Size = UDim2.new(1, 0, 0, totalHeight)
    end
end

