local function globalESPUpdate()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer then
			local isTeamDisabled = p.Team and _G.DisabledTeams[p.Team.Name]
			local failedTeamCheck = _G.TeamCheck and p.Team == LocalPlayer.Team

			if _G.ESPEnabled and not isTeamDisabled and not failedTeamCheck then
				if not playerLabels[p] then graphics.createESPLabel(p) end
				graphics.createESPHighlight(p)
				if p.Character then
					local hum = p.Character:FindFirstChildOfClass("Humanoid")
					if hum then utils.safeSetProperty(hum, "DisplayDistanceType", Enum.HumanoidDisplayDistanceType.None) end
				end
			else
				graphics.removeESPHighlight(p)
				graphics.removeESPLabel(p)
				if p.Character then
					local hum = p.Character:FindFirstChildOfClass("Humanoid")
					if hum then utils.safeSetProperty(hum, "DisplayDistanceType", Enum.HumanoidDisplayDistanceType.Viewer) end
				end
			end
		end
	end
